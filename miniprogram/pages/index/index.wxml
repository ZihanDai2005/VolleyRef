<view class="room-container">
	<view class="room-id">房间号：{{roomId}}</view>
	<view class="section-title">设置比赛基础信息</view>
	<match-settings bind:confirm="onSettingsConfirm" />
	<view class="section-title">设置首发阵容</view>
	<court-view teamType="A" players="{{teamAPlayers}}" onPlayerChange="onPlayerChangeA" />
	<court-view teamType="B" players="{{teamBPlayers}}" onPlayerChange="onPlayerChangeB" />
	<button class="start-btn" bindtap="onStartMatch">确认首发并开始比赛</button>
</view>

