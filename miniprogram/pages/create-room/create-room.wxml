<view class="entry-container">
  <view class="entry-card">
    <text class="title">创建裁判团队</text>

    <view class="pin-input-wrap">
      <input
        class="pin-native-input"
        type="text"
        maxlength="6"
        value="{{createRoomId}}"
        bindinput="onCreateRoomIdInput"
      />
      <view class="pin-display">
        <text>{{createRoomId}}{{createRoomIdDots}}</text>
      </view>
    </view>

    <view class="pin-input-wrap">
      <input
        class="pin-native-input"
        type="text"
        maxlength="6"
        value="{{createPassword}}"
        bindinput="onCreatePasswordInput"
      />
      <view class="pin-display">
        <text>{{createPassword}}{{createPasswordDots}}</text>
      </view>
    </view>

    <button class="enter-btn" bindtap="onCreateRoomSubmit">创建裁判团队</button>
  </view>

  <view class="entry-card join-card">
    <text class="title">加入裁判团队</text>

    <view class="pin-input-wrap">
      <input
        class="pin-native-input"
        type="text"
        maxlength="6"
        value="{{joinRoomId}}"
        bindinput="onJoinRoomIdInput"
      />
      <view class="pin-display">
        <text>{{joinRoomId}}{{joinRoomIdDots}}</text>
      </view>
    </view>

    <view class="pin-input-wrap">
      <input
        class="pin-native-input"
        type="text"
        maxlength="6"
        value="{{joinPassword}}"
        bindinput="onJoinPasswordInput"
      />
      <view class="pin-display">
        <text>{{joinPassword}}{{joinPasswordDots}}</text>
      </view>
    </view>

    <button class="enter-btn join-btn" bindtap="onJoinRoomSubmit">加入裁判团队</button>
  </view>
</view>
