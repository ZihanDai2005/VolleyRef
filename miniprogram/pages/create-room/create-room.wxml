<view
  class="room-container {{createMode ? 'create-mode' : ''}}"
  style="--team-a-color: {{teamAColor}}; --team-b-color: {{teamBColor}}; --custom-nav-offset: {{customNavOffset}};"
  bindtap="onCreateBlankTap"
>
  <view class="custom-nav-bg" style="height: {{customNavOffset}};"></view>
  <view
    class="custom-nav"
    style="top: {{customNavTop}}; left: {{createMode ? '64rpx' : '30rpx'}}; right: {{createMode ? '64rpx' : '30rpx'}};"
  >
    <view class="custom-nav-back pressable" hover-class="tap-active" bindtap="onBackTap">
      <view class="custom-nav-back-icon"></view>
    </view>
    <view class="custom-nav-space"></view>
  </view>

  <view class="create-head-block" wx:if="{{createMode}}">
    <text class="create-head-title">开始一个新的</text>
    <view class="create-head-title create-head-title-second">
      <text>裁判协作</text>
      <text class="title-special-dot">.</text>
    </view>

    <view class="create-head-inputs">
      <view class="create-head-hint-row">
        <text class="create-head-hint">裁判团队编号</text>
        <view class="room-id-info-btn pressable" hover-class="tap-active" bindtap="onRoomIdInfoTap">
          <view class="room-id-info-icon"></view>
        </view>
      </view>
      <view class="create-head-input-wrap create-head-input-wrap-readonly">
        <view class="create-head-input create-head-input-display create-head-input-readonly">
          <text class="create-head-input-display-text room-pass-display-text">{{roomIdSpaced}}</text>
        </view>
      </view>

      <text class="create-head-hint">设置6位密码</text>
      <view class="create-head-input-wrap" catchtap="onCreatePasswordWrapTap">
        <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
          class="create-head-input-native"
          type="number"
          maxlength="6"
          value="{{roomPassword}}"
          focus="{{focusCreatePasswordInput}}"
          cursor="{{roomPassword.length}}"
          data-field="roomPassword"
          bindfocus="onPasswordFocus"
          bindblur="onPasswordBlur"
          bindinput="onInputChange"
        />
        <view class="create-head-input create-head-input-display">
          <text class="create-head-input-display-text room-pass-display-text">{{roomPasswordSpaced}}</text>
          <text class="fake-caret create-password-caret {{focusCreatePasswordInput && passwordFocused && roomPassword.length < 6 ? 'active' : ''}}"></text>
        </view>
      </view>

      <text class="create-head-hint">赛制模式</text>
      <picker
        mode="selector"
        range="{{matchModes}}"
        range-key="label"
        value="{{matchModeIndex}}"
        disabled="{{!createMode}}"
        bindchange="onMatchModeChange"
      >
        <view class="create-head-input-wrap create-head-mode-wrap">
          <view class="create-head-input create-head-input-mode">
            <text class="create-head-mode-text">{{(matchModes[matchModeIndex] || matchModes[0]).label}}</text>
          </view>
          <view class="create-head-mode-arrow"></view>
        </view>
      </picker>
      <view class="create-head-hint-alert-row">
        <text class="create-head-hint create-head-hint-alert">请妥善保存团队编号和密码，否则退出后无法重新进入。</text>
      </view>

      <view class="create-head-divider-wrap">
        <view class="create-head-divider"></view>
      </view>

      <text class="create-head-section-title">甲队设置</text>
      <view class="create-head-color-draw-wrap">
        <view class="create-head-color-col">
          <text class="create-head-hint">颜色</text>
          <view class="color-options create-head-color-options">
            <view
              class="color-option {{teamAColor === item.value ? 'active' : ''}} {{teamBColor === item.value ? 'disabled' : ''}}"
              wx:for="{{colorOptions}}"
              wx:key="value"
              style="color: {{item.value}};"
              data-team="A"
              data-color="{{item.value}}"
              hover-class="{{createMode ? 'color-option-hover' : ''}}"
              bindtap="onTeamColorSelect"
            >
              <view class="color-dot" style="background-color: {{item.value}};"></view>
              <view wx:if="{{teamBColor === item.value}}" class="color-dot-slash"></view>
            </view>
          </view>
        </view>
        <view class="create-head-draw-col">
          <text class="create-head-hint">抽签结果</text>
          <view class="team-switches create-head-draw-switches">
            <view
              class="toggle-item switch-btn pressable {{servingTeam === 'A' ? 'on' : ''}} {{servePulseTeam === 'A' ? 'switch-pulse' : ''}}"
              data-team="A"
              hover-class="tap-active"
              bindtap="onTeamServeButton"
            >
              <view class="draw-toggle-content">
                <view class="serve-toggle-icon draw-toggle-icon {{servingTeam === 'A' ? 'serve' : 'receive'}}"></view>
                <text class="toggle-text draw-toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
              </view>
            </view>
            <view class="side-toggle-btn switch-btn pressable {{teamASide === 'A' ? 'on' : ''}} {{sidePulse ? 'switch-pulse' : ''}}" hover-class="tap-active" bindtap="onToggleTeamSide">
              <view class="draw-toggle-content">
                <view class="side-toggle-icon draw-toggle-icon"></view>
                <text class="toggle-text draw-toggle-text">
                  <text class="draw-ab-letter">{{teamASide === 'A' ? 'A' : 'B'}}</text>场区
                </text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <text class="create-head-hint">名称</text>
      <view class="create-head-input-wrap create-team-input-wrap" catchtap="onCreateFieldWrapTap" data-focus-key="teamAName">
        <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
          class="create-head-input-native"
          value="{{teamAName}}"
          focus="{{activeCreateInputKey === 'teamAName'}}"
          disabled="{{!createMode}}"
          data-field="teamAName"
          data-focus-key="teamAName"
          bindfocus="onTeamNameFocus"
          bindblur="onTeamNameBlur"
          bindinput="onInputChange"
        />
        <view class="create-head-input create-team-input-display">
          <text class="create-team-input-display-text">{{teamAName || (teamANameFocused ? '' : '甲')}}</text>
          <text class="fake-caret create-password-caret {{activeCreateInputKey === 'teamAName' ? 'active' : ''}}"></text>
        </view>
      </view>
      <view class="create-head-lineup-row">
        <text class="create-head-hint create-head-lineup-hint">首发队员</text>
      </view>

      <view class="create-head-lineup-card">
        <view class="lineup-grid create-head-lineup-grid team-a {{teamASide === 'A' ? 'side-a' : 'side-b'}} {{sidePulse ? 'side-switching' : ''}}">
          <view class="main-col">
            <view class="player-row row-two" wx:for="{{teamAMainGrid}}" wx:for-item="row" wx:key="index">
              <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos" catchtap="onCreateFieldWrapTap" data-focus-key="{{item.inputKey}}">
                <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
                  class="create-head-input-native"
                  type="number"
                  maxlength="2"
                  value="{{item.number === '?' ? '' : item.number}}"
                  focus="{{activeCreateInputKey === item.inputKey}}"
                  data-team="A"
                  data-index="{{item.index}}"
                  data-focus-key="{{item.inputKey}}"
                  bindfocus="onPlayerNumberFocus"
                  bindinput="onPlayerNumberInput"
                  bindblur="onPlayerNumberBlur"
                />
                <view class="player-edit-content">
                  <text class="fake-caret player-fake-caret before {{activeCreateInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                  <text class="num-text" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                  <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                  <text class="fake-caret player-fake-caret {{activeCreateInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
                </view>
                <text class="sub-text">{{item.pos}}</text>
              </view>
            </view>
          </view>
          <view class="libero-col">
            <view class="player-card libero" wx:for="{{teamALibero}}" wx:for-item="item" wx:key="pos" catchtap="onCreateFieldWrapTap" data-focus-key="{{item.inputKey}}">
              <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
                class="create-head-input-native"
                type="number"
                maxlength="2"
                value="{{item.number === '?' ? '' : item.number}}"
                focus="{{activeCreateInputKey === item.inputKey}}"
                data-team="A"
                data-index="{{item.index}}"
                data-focus-key="{{item.inputKey}}"
                bindfocus="onPlayerNumberFocus"
                bindinput="onPlayerNumberInput"
                bindblur="onPlayerNumberBlur"
              />
              <view class="player-edit-content">
                <text class="fake-caret player-fake-caret before {{activeCreateInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                <text class="num-text" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                <text class="fake-caret player-fake-caret {{activeCreateInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
              </view>
              <text class="sub-text">{{item.pos}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="create-head-captain-row">
        <text class="create-head-hint">球队队长号码</text>
        <view class="create-head-input-wrap create-team-input-wrap" catchtap="onCreateFieldWrapTap" data-focus-key="teamACaptainNo">
          <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
            class="create-head-input-native create-captain-input-native"
            type="number"
            maxlength="2"
            value="{{teamACaptainNo}}"
            data-field="teamACaptainNo"
            data-focus-key="teamACaptainNo"
            focus="{{activeCreateInputKey === 'teamACaptainNo'}}"
            bindfocus="onPlayerNumberFocus"
            bindinput="onInputChange"
            bindblur="onCaptainNoBlur"
          />
          <view class="create-head-input create-team-input-display">
            <text class="create-team-input-display-text create-captain-input-display-text">{{teamACaptainNo}}</text>
            <text class="fake-caret create-password-caret {{activeCreateInputKey === 'teamACaptainNo' ? 'active' : ''}}"></text>
          </view>
        </view>
      </view>

      <view class="create-head-divider-wrap">
        <view class="create-head-divider"></view>
      </view>

      <text class="create-head-section-title create-head-team-gap">乙队设置</text>
      <view class="create-head-color-draw-wrap">
        <view class="create-head-color-col">
          <text class="create-head-hint">颜色</text>
          <view class="color-options create-head-color-options">
            <view
              class="color-option {{teamBColor === item.value ? 'active' : ''}} {{teamAColor === item.value ? 'disabled' : ''}}"
              wx:for="{{colorOptions}}"
              wx:key="value"
              style="color: {{item.value}};"
              data-team="B"
              data-color="{{item.value}}"
              hover-class="{{createMode ? 'color-option-hover' : ''}}"
              bindtap="onTeamColorSelect"
            >
              <view class="color-dot" style="background-color: {{item.value}};"></view>
              <view wx:if="{{teamAColor === item.value}}" class="color-dot-slash"></view>
            </view>
          </view>
        </view>
        <view class="create-head-draw-col">
          <text class="create-head-hint">抽签结果</text>
          <view class="team-switches create-head-draw-switches">
            <view
              class="toggle-item switch-btn pressable {{servingTeam === 'B' ? 'on' : ''}} {{servePulseTeam === 'B' ? 'switch-pulse' : ''}}"
              data-team="B"
              hover-class="tap-active"
              bindtap="onTeamServeButton"
            >
              <view class="draw-toggle-content">
                <view class="serve-toggle-icon draw-toggle-icon {{servingTeam === 'B' ? 'serve' : 'receive'}}"></view>
                <text class="toggle-text draw-toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
              </view>
            </view>
            <view class="side-toggle-btn switch-btn pressable {{teamASide === 'B' ? 'on' : ''}} {{sidePulse ? 'switch-pulse' : ''}}" hover-class="tap-active" bindtap="onToggleTeamSide">
              <view class="draw-toggle-content">
                <view class="side-toggle-icon draw-toggle-icon"></view>
                <text class="toggle-text draw-toggle-text">
                  <text class="draw-ab-letter">{{teamASide === 'B' ? 'A' : 'B'}}</text>场区
                </text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <text class="create-head-hint">名称</text>
      <view class="create-head-input-wrap create-team-input-wrap" catchtap="onCreateFieldWrapTap" data-focus-key="teamBName">
        <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
          class="create-head-input-native"
          value="{{teamBName}}"
          focus="{{activeCreateInputKey === 'teamBName'}}"
          disabled="{{!createMode}}"
          data-field="teamBName"
          data-focus-key="teamBName"
          bindfocus="onTeamNameFocus"
          bindblur="onTeamNameBlur"
          bindinput="onInputChange"
        />
        <view class="create-head-input create-team-input-display">
          <text class="create-team-input-display-text">{{teamBName || (teamBNameFocused ? '' : '乙')}}</text>
          <text class="fake-caret create-password-caret {{activeCreateInputKey === 'teamBName' ? 'active' : ''}}"></text>
        </view>
      </view>
      <view class="create-head-lineup-row">
        <text class="create-head-hint create-head-lineup-hint">首发队员</text>
      </view>

      <view class="create-head-lineup-card">
        <view class="lineup-grid create-head-lineup-grid team-b {{teamASide === 'B' ? 'side-a' : 'side-b'}} {{sidePulse ? 'side-switching' : ''}}">
          <view class="main-col">
            <view class="player-row row-two" wx:for="{{teamBMainGrid}}" wx:for-item="row" wx:key="index">
              <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos" catchtap="onCreateFieldWrapTap" data-focus-key="{{item.inputKey}}">
                <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
                  class="create-head-input-native"
                  type="number"
                  maxlength="2"
                  value="{{item.number === '?' ? '' : item.number}}"
                  focus="{{activeCreateInputKey === item.inputKey}}"
                  data-team="B"
                  data-index="{{item.index}}"
                  data-focus-key="{{item.inputKey}}"
                  bindfocus="onPlayerNumberFocus"
                  bindinput="onPlayerNumberInput"
                  bindblur="onPlayerNumberBlur"
                />
                <view class="player-edit-content">
                  <text class="fake-caret player-fake-caret before {{activeCreateInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                  <text class="num-text" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                  <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                  <text class="fake-caret player-fake-caret {{activeCreateInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
                </view>
                <text class="sub-text">{{item.pos}}</text>
              </view>
            </view>
          </view>
          <view class="libero-col">
            <view class="player-card libero" wx:for="{{teamBLibero}}" wx:for-item="item" wx:key="pos" catchtap="onCreateFieldWrapTap" data-focus-key="{{item.inputKey}}">
              <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
                class="create-head-input-native"
                type="number"
                maxlength="2"
                value="{{item.number === '?' ? '' : item.number}}"
                focus="{{activeCreateInputKey === item.inputKey}}"
                data-team="B"
                data-index="{{item.index}}"
                data-focus-key="{{item.inputKey}}"
                bindfocus="onPlayerNumberFocus"
                bindinput="onPlayerNumberInput"
                bindblur="onPlayerNumberBlur"
              />
              <view class="player-edit-content">
                <text class="fake-caret player-fake-caret before {{activeCreateInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                <text class="num-text" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                <text class="fake-caret player-fake-caret {{activeCreateInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
              </view>
              <text class="sub-text">{{item.pos}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="create-head-captain-row">
        <text class="create-head-hint">球队队长号码</text>
        <view class="create-head-input-wrap create-team-input-wrap" catchtap="onCreateFieldWrapTap" data-focus-key="teamBCaptainNo">
          <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
            class="create-head-input-native create-captain-input-native"
            type="number"
            maxlength="2"
            value="{{teamBCaptainNo}}"
            data-field="teamBCaptainNo"
            data-focus-key="teamBCaptainNo"
            focus="{{activeCreateInputKey === 'teamBCaptainNo'}}"
            bindfocus="onPlayerNumberFocus"
            bindinput="onInputChange"
            bindblur="onCaptainNoBlur"
          />
          <view class="create-head-input create-team-input-display">
            <text class="create-team-input-display-text create-captain-input-display-text">{{teamBCaptainNo}}</text>
            <text class="fake-caret create-password-caret {{activeCreateInputKey === 'teamBCaptainNo' ? 'active' : ''}}"></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="card team team-a" wx:if="{{!createMode}}">
    <view class="team-head-row">
      <text class="team-title">{{teamAName || '甲'}}队 首发队员</text>
      <view class="team-switches">
        <view
          class="toggle-item switch-btn pressable {{servingTeam === 'A' ? 'on' : ''}} {{servePulseTeam === 'A' ? 'switch-pulse' : ''}}"
          data-team="A"
          hover-class="tap-active"
          bindtap="onTeamServeButton"
        >
          <text class="toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
          <view class="serve-toggle-icon {{servingTeam === 'A' ? 'serve' : 'receive'}}"></view>
        </view>
        <view class="side-toggle-btn switch-btn pressable {{sidePulse ? 'switch-pulse' : ''}}" hover-class="tap-active" bindtap="onToggleTeamSide">
          <text><text class="draw-ab-letter">{{teamASide === 'A' ? 'A' : 'B'}}</text>场区</text>
          <view class="side-toggle-icon"></view>
        </view>
      </view>
    </view>

    <view class="lineup-grid team-a">
      <view class="main-col">
        <view class="player-row row-two" wx:for="{{teamAMainGrid}}" wx:for-item="row" wx:key="index">
          <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos">
            <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0" class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="A" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="libero-col">
        <view class="player-card libero" wx:for="{{teamALibero}}" wx:for-item="item" wx:key="pos">
          <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0" class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="A" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
          <text class="sub-text">{{item.pos}}</text>
        </view>
      </view>
    </view>

    <view class="setting-row captain-row">
      <text class="label">队长号码</text>
      <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
        class="input team-name input-left"
        type="number"
        maxlength="2"
        value="{{teamACaptainNo}}"
        data-field="teamACaptainNo"
        bindinput="onInputChange"
        bindblur="onCaptainNoBlur"
      />
    </view>
  </view>

  <view class="card team team-b" wx:if="{{!createMode}}">
    <view class="team-head-row">
      <text class="team-title">{{teamBName || '乙'}}队 首发队员</text>
      <view class="team-switches">
        <view
          class="toggle-item switch-btn pressable {{servingTeam === 'B' ? 'on' : ''}} {{servePulseTeam === 'B' ? 'switch-pulse' : ''}}"
          data-team="B"
          hover-class="tap-active"
          bindtap="onTeamServeButton"
        >
          <text class="toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
          <view class="serve-toggle-icon {{servingTeam === 'B' ? 'serve' : 'receive'}}"></view>
        </view>
        <view class="side-toggle-btn switch-btn pressable {{sidePulse ? 'switch-pulse' : ''}}" hover-class="tap-active" bindtap="onToggleTeamSide">
          <text><text class="draw-ab-letter">{{teamASide === 'B' ? 'A' : 'B'}}</text>场区</text>
          <view class="side-toggle-icon"></view>
        </view>
      </view>
    </view>

    <view class="lineup-grid team-b">
      <view class="main-col">
        <view class="player-row row-two" wx:for="{{teamBMainGrid}}" wx:for-item="row" wx:key="index">
          <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos">
            <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0" class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="B" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="libero-col">
        <view class="player-card libero" wx:for="{{teamBLibero}}" wx:for-item="item" wx:key="pos">
          <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0" class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="B" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
          <text class="sub-text">{{item.pos}}</text>
        </view>
      </view>
    </view>

    <view class="setting-row captain-row">
      <text class="label">队长号码</text>
      <input adjust-position="false" always-embed="true" hold-keyboard="true" cursor-spacing="0"
        class="input team-name input-left"
        type="number"
        maxlength="2"
        value="{{teamBCaptainNo}}"
        data-field="teamBCaptainNo"
        bindinput="onInputChange"
        bindblur="onCaptainNoBlur"
      />
    </view>
  </view>

  <view class="create-actions" wx:if="{{createMode}}">
    <text class="create-invite-reminder">请核对信息 进入比赛后不可修改</text>
    <button class="entry-btn create-invite-btn {{createInviteBtnFx ? 'entry-btn-fx' : ''}}" hover-class="entry-btn-hover" bindtap="onCreateInviteTap">
      <view class="entry-btn-content">
        <view class="entry-btn-copy-icon"></view>
        <text class="entry-btn-text">复制邀请</text>
      </view>
    </button>
    <button class="entry-btn {{createContinueBtnFx ? 'entry-btn-fx' : ''}}" hover-class="entry-btn-hover" bindtap="onCreateContinueTap">
      <view class="entry-btn-content">
        <text class="entry-btn-text">继续</text>
        <view class="entry-btn-icon"></view>
      </view>
    </button>
  </view>
  <button class="save-btn" wx:if="{{!createMode}}" bindtap="onSaveAndStart">进入比赛</button>

</view>
