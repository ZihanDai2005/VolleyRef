<view class="landing-container">
  <view class="screen-container" style="--custom-nav-offset: {{customNavOffset}};">
    <view
      class="quick-resume-entry pressable {{quickResumeVisible ? 'is-visible' : 'is-hidden'}}"
      hover-class="tap-active"
      bindtap="onQuickResumeTap"
    >
      <view class="quick-resume-main">
        <text class="quick-resume-title">{{quickResumeTitle}}</text>
        <text class="quick-resume-subtitle">{{quickResumeSubtitle}}</text>
      </view>
      <view class="quick-resume-action">
        <text class="quick-resume-action-text">进入</text>
        <view class="quick-resume-action-icon"></view>
      </view>
    </view>

    <view class="court-motif">
      <view class="court-line line-center"></view>
      <view class="court-line line-attack-top"></view>
      <view class="court-line line-attack-bottom"></view>
    </view>

    <view class="content-layer">
      <view class="logo-group">
        <text class="brand-title">VOLLEY</text>
        <view class="brand-line-two">
          <text class="brand-title">REF</text>
          <text class="brand-dot">.</text>
        </view>
        <text class="brand-subtitle">排球裁判协作系统</text>
      </view>

      <view class="button-group">
        <button class="pill-button pill-primary {{createBtnFx ? 'entry-btn-fx' : ''}}" hover-class="entry-btn-hover" bindtap="onCreateEntryTap">
          <view class="pill-btn-content">
            <text class="pill-btn-text">创建比赛</text>
            <view class="pill-btn-icon"></view>
          </view>
        </button>
        <button class="pill-button pill-secondary {{joinBtnFx ? 'entry-btn-fx' : ''}}" hover-class="entry-btn-hover" bindtap="onJoinEntryTap">
          <view class="pill-btn-content">
            <text class="pill-btn-text">加入比赛</text>
            <view class="pill-btn-icon"></view>
          </view>
        </button>
      </view>
    </view>

    <view class="version-row">
      <text class="version-tag">V1.5.4</text>
      <text class="version-sep">|</text>
      <button class="version-link version-link-contact" open-type="contact" hover-class="version-link-hover">
        <text class="version-link-text">联系我们</text>
      </button>
      <view class="version-link version-guide-entry pressable" hover-class="version-link-hover" bindtap="onOpenGuidePage">
        <text class="version-link-text">使用指南</text>
      </view>
    </view>
  </view>
</view>
