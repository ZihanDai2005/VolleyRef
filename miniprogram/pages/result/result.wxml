<view class="result-page" style="--custom-nav-offset: {{customNavOffset}};">
  <view class="custom-nav-bg result-custom-nav-bg" style="height: {{customNavOffset}};"></view>
  <view class="custom-nav result-custom-nav" style="top: {{customNavTop}}; left: 64rpx; right: 64rpx;">
    <view class="custom-nav-back pressable" hover-class="tap-active" bindtap="onBackTap">
      <view class="custom-nav-back-icon"></view>
    </view>
    <view class="result-custom-nav-title">比赛结果</view>
    <view class="custom-nav-space"></view>
  </view>
  <view class="result-nav-spacer" style="height: calc({{customNavOffset}} + 24rpx);"></view>

  <view class="result-content">
    <view class="result-countdown-row" wx:if="{{clearCountdownText}}">
      <text class="result-countdown">{{clearCountdownText}}</text>
    </view>

    <view class="result-score-panel">
      <view class="result-sheet-btn pressable" hover-class="tap-active" bindtap="onScoreSheetTap">记分表</view>
      <text class="result-section-label">比局</text>
      <view class="result-compare-line">
        <text class="result-compare-left">{{teamAName}}</text>
        <text class="result-compare-colon">:</text>
        <text class="result-compare-right">{{teamBName}}</text>
      </view>
      <view class="result-score-line">
        <text class="result-score">{{bigScoreA}}</text>
        <text class="result-score-sep">:</text>
        <text class="result-score">{{bigScoreB}}</text>
      </view>
    </view>

    <view class="result-set-switch" wx:if="{{setOptions.length > 1}}">
      <text class="result-set-label">局</text>
      <view class="result-set-seg">
        <view
          class="result-set-item {{selectedSetNo === item ? 'active' : ''}}"
          wx:for="{{setOptions}}"
          wx:key="*this"
          wx:for-item="item"
          data-set-no="{{item}}"
          bindtap="onSelectSet"
        >{{item}}</view>
      </view>
    </view>

    <view class="result-score-panel">
      <text class="result-section-label">第{{selectedSetNo}}局比分</text>
      <view class="result-compare-line">
        <text class="result-compare-left">{{teamAName}}</text>
        <text class="result-compare-colon">:</text>
        <text class="result-compare-right">{{teamBName}}</text>
      </view>
      <view class="result-score-line">
        <text class="result-score">{{selectedSmallScoreA}}</text>
        <text class="result-score-sep">:</text>
        <text class="result-score">{{selectedSmallScoreB}}</text>
      </view>
      <text class="result-winner" wx:if="{{selectedSetWinnerText}}">{{selectedSetWinnerText}}</text>
      <text class="result-duration" wx:if="{{selectedSetDurationText}}">{{selectedSetDurationText}}</text>
    </view>

    <view class="result-log-card">
      <view class="result-log-head">第{{selectedSetNo}}局操作记录</view>
      <view class="result-log-list">
        <view class="result-log-item" wx:for="{{logs}}" wx:key="id" wx:for-item="item">
          <text class="result-log-time">{{item.timeText}}</text>
          <text class="result-log-note">{{item.note}}</text>
        </view>
        <view class="result-log-empty" wx:if="{{!logs.length}}">暂无记录</view>
      </view>
    </view>
  </view>
  <canvas
    type="2d"
    id="scoreSheetCanvas"
    canvas-id="scoreSheetCanvas"
    class="score-sheet-canvas"
    style="width: 640px; height: 635px;"
  ></canvas>
</view>
