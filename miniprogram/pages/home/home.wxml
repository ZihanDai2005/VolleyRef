<view class="landing-container">
  <view class="screen-container">
    <view class="court-motif">
      <view class="court-line line-center"></view>
      <view class="court-line line-attack-top"></view>
      <view class="court-line line-attack-bottom"></view>
    </view>

    <view class="content-layer">
      <view class="logo-group">
        <text class="brand-title">VOLLEY</text>
        <view class="brand-line-two">
          <text class="brand-title">REF</text>
          <text class="brand-dot">.</text>
        </view>
        <text class="brand-subtitle">排球裁判协作系统</text>
      </view>

      <view class="button-group">
        <button class="pill-button pill-primary {{createBtnFx ? 'entry-btn-fx' : ''}}" hover-class="entry-btn-hover" bindtap="onCreateEntryTap">
          创建新比赛
        </button>
        <button class="pill-button pill-secondary {{joinBtnFx ? 'entry-btn-fx' : ''}}" hover-class="entry-btn-hover" bindtap="onJoinEntryTap">
          加入既有比赛
        </button>
      </view>
    </view>

    <text class="version-tag">1.2.0</text>
  </view>
</view>
