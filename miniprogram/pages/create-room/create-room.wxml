<view class="entry-container">
  <view class="entry-shell">
    <view class="entry-section">
      <text class="title">开始一场比赛</text>
      <text class="subtitle">请设置6位房间密码，房间号码将自动分配</text>

      <view class="pin-input-wrap">
        <input
          class="pin-native-input"
          type="number"
          maxlength="6"
          value="{{createPassword}}"
          bindinput="onCreatePasswordInput"
        />
        <view class="pin-display">
          <text>{{createPassword}}{{createPasswordDots}}</text>
        </view>
      </view>

      <button class="enter-btn" bindtap="onCreateRoomSubmit">创建</button>
    </view>

    <view class="section-divider"></view>

    <view class="entry-section">
      <text class="title">加入一场比赛</text>
      <text class="subtitle">请输入6位房间号码和密码</text>

      <view class="pin-input-wrap">
        <input
          class="pin-native-input"
          type="number"
          maxlength="6"
          value="{{joinRoomId}}"
          bindinput="onJoinRoomIdInput"
        />
        <view class="pin-display">
          <text>{{joinRoomId}}{{joinRoomIdDots}}</text>
        </view>
      </view>

      <view class="pin-input-wrap">
        <input
          class="pin-native-input"
          type="number"
          maxlength="6"
          value="{{joinPassword}}"
          bindinput="onJoinPasswordInput"
        />
        <view class="pin-display">
          <text>{{joinPassword}}{{joinPasswordDots}}</text>
        </view>
      </view>

      <button class="enter-btn join-btn" bindtap="onJoinRoomSubmit">加入</button>
      <button class="paste-link-btn" bindtap="onPasteInviteAndJoin">
        <view class="link-content">
          <view class="paste-icon"></view>
          <text>粘贴邀请信息直接加入</text>
        </view>
      </button>
    </view>
  </view>
</view>
