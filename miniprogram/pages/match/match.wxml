<view
  class="match-page match-container"
  style="--team-a-color: {{teamAColor}}; --team-b-color: {{teamBColor}}; --team-a-rgb: {{teamARGB}}; --team-b-rgb: {{teamBRGB}}; --safe-pad-top: {{safePadTop}}; --safe-pad-right: {{safePadRight}}; --safe-pad-bottom: {{safePadBottom}}; --safe-pad-left: {{safePadLeft}};"
>
  <view class="match-nav">
    <view class="match-nav-left">
      <view class="match-nav-back pressable" hover-class="tap-active" bindtap="confirmBackToHome">
        <view class="match-nav-back-icon"></view>
      </view>
      <view
        wx:if="{{!hasOperationAuthority}}"
        class="takeover-btn {{showSetEndModal ? 'set-end-open' : ''}} pressable"
        hover-class="tap-active"
        bindtap="onTakeoverTap"
      >
        <view class="takeover-btn-icon"></view>
        <text class="takeover-btn-text">接管</text>
      </view>
    </view>
    <view class="match-nav-title">
      <text>裁判团队编号 {{roomId}}</text>
      <view class="conn-inline {{connStatusClass}}">
        <view class="conn-inline-icon"></view>
        <text class="conn-inline-text">{{connStatusText}}</text>
      </view>
    </view>
    <view class="match-nav-space"></view>
  </view>
  <view class="top-control-row">
    <view class="x-zone">
      <view class="x-row">
        <view wx:if="{{hasOperationAuthority}}" class="action-btn icon-circle-btn pressable" hover-class="tap-active" bindtap="onSwitchSides">
          <view class="btn-icon icon-switch"></view>
        </view>
        <view wx:else class="action-btn perspective-btn pressable" hover-class="tap-active" bindtap="onToggleObserverPerspective">
          <view class="btn-icon icon-switch"></view>
          <text class="perspective-btn-text">视角</text>
        </view>
        <view
          wx:if="{{hasOperationAuthority}}"
          class="action-btn icon-circle-btn pressable"
          hover-class="tap-active"
          bindtap="onUndoLastScore"
        >
          <view class="btn-icon icon-undo"></view>
        </view>
        <view class="action-btn icon-circle-btn pressable" hover-class="tap-active" bindtap="onOpenLogPanel">
          <view class="btn-icon icon-log"></view>
        </view>
      </view>
      <view class="x-row">
        <view class="x-room-count-pill online-pill">
          <view class="online-judge-icon"></view>
          <text>{{participantCount}}</text>
        </view>
        <view class="x-room-count-pill mode-pill">{{hasOperationAuthority ? '裁判模式' : '观赛模式'}}</view>
      </view>
    </view>

    <view class="score-zone {{switchingOut ? 'switch-out' : ''}} {{switchingIn ? 'switch-in' : ''}}">
      <view class="score-pill-row">
        <view class="center-pill-switch">
          <view class="x-room-count-pill center-set-pill stat-num-pill score-switch-pill {{(canStartMatch && hasOperationAuthority) ? 'pill-hidden' : 'pill-visible'}}">{{setWinsText}}</view>
          <view wx:if="{{hasOperationAuthority}}" class="start-match-entry-row score-switch-pill {{canStartMatch ? 'pill-visible' : 'pill-hidden'}}">
            <view
              class="x-room-count-pill center-set-pill reconfigure-entry-pill pressable"
              hover-class="tap-active"
              bindtap="onReconfigurePlayersTap"
            >
              <view class="reconfigure-entry-icon"></view>
              <text class="reconfigure-entry-text">重新配置球员</text>
            </view>
            <view
              class="x-room-count-pill center-set-pill start-match-entry-pill pressable"
              hover-class="tap-active"
              bindtap="onOpenStartMatchModal"
            >
              <view class="start-match-entry-icon"></view>
              <text class="start-match-entry-text">开始比赛</text>
            </view>
          </view>
        </view>
        <view class="timeout-live-pill {{timeoutActive ? 'active' : 'inactive'}} {{hasOperationAuthority ? '' : 'observer'}}">
          <text class="timeout-live-text">{{timeoutLeftText}}</text>
          <view
            wx:if="{{hasOperationAuthority}}"
            class="timeout-live-end-btn pressable"
            hover-class="tap-active"
            bindtap="onEndTimeoutTap"
          >
            <text class="timeout-live-end-label">结束</text>
          </view>
        </view>
      </view>
      <score-board
        aScore="{{aScore}}"
        bScore="{{bScore}}"
        lastScoringTeam="{{lastScoringTeam}}"
        allowScore="{{hasOperationAuthority}}"
        bind:scoreChange="onScoreChange"
      />
    </view>

    <view class="y-zone">
      <view class="y-row">
        <view class="x-room-count-pill">{{matchModeText}}</view>
        <view class="x-room-count-pill">{{setNoText}}</view>
      </view>
      <view class="y-row">
        <view class="x-room-count-pill timer-pill"><text class="timer-pill-text">局时间 {{setTimerText}}</text></view>
      </view>
    </view>
  </view>

  <view class="court-row {{isSwapped ? 'swapped' : ''}} {{switchingOut ? 'switch-out' : ''}} {{switchingIn ? 'switch-in' : ''}}">
    <view class="team-panel team-a">
      <view class="team-head">
        <block wx:if="{{!isSwapped}}">
          <view class="team-actions left">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="A" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="A"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="A" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
          <text class="team-title align-right">{{teamAName}}</text>
        </block>
        <block wx:else>
          <text class="team-title align-left">{{teamAName}}</text>
          <view class="team-actions right">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="A" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="A"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="A" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
        </block>
      </view>
      <view class="lineup-grid {{isSwapped ? 'swap-layout' : ''}}">
        <view class="libero-col">
          <view
            id="swap-card-A-{{item.pos}}"
            class="player-card libero {{swapDragActive && swapDragTeam === 'A' && swapDragPos === item.pos ? 'swap-drag-source' : ''}} {{swapDragActive && swapDragTeam === 'A' && swapDragPos !== item.pos && swapDragSourceInMain && ((item.pos === 'L1' && swapDragTargetL1) || (item.pos === 'L2' && swapDragTargetL2)) ? 'swap-drag-target' : ''}}"
            wx:for="{{teamALibero}}"
            wx:for-item="item"
            wx:key="pos"
            data-team="A"
            data-pos="{{item.pos}}"
            catchtouchstart="onSwapCardTouchStart"
            catchtouchmove="onSwapCardTouchMove"
            catchtouchend="onSwapCardTouchEnd"
            catchtouchcancel="onSwapCardTouchEnd"
          >
            <text class="num {{item.number === teamACaptainNo ? 'captain-num' : ''}} {{item.isLibero ? 'libero-dot' : ''}}">{{item.number}}</text>
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
        <view class="main-col">
          <view class="player-row row-two" wx:for="{{teamAMainGrid}}" wx:for-item="row" wx:key="index">
            <view
              id="swap-card-A-{{item.pos}}"
              class="player-card pos-card-{{item.pos}} {{item.pos === 'I' && servingTeam === 'A' ? 'score-pos-one' : ''}} {{swapDragActive && swapDragTeam === 'A' && swapDragPos === item.pos ? 'swap-drag-source' : ''}} {{swapDragActive && swapDragTeam === 'A' && swapDragPos !== item.pos && swapDragSourceIsLibero && ((item.pos === 'I' && swapDragTargetI) || (item.pos === 'II' && swapDragTargetII) || (item.pos === 'III' && swapDragTargetIII) || (item.pos === 'IV' && swapDragTargetIV) || (item.pos === 'V' && swapDragTargetV) || (item.pos === 'VI' && swapDragTargetVI)) ? 'swap-drag-target' : ''}}"
              wx:for="{{row}}"
              wx:for-item="item"
              wx:key="pos"
              data-team="A"
              data-pos="{{item.pos}}"
              catchtouchstart="onSwapCardTouchStart"
              catchtouchmove="onSwapCardTouchMove"
              catchtouchend="onSwapCardTouchEnd"
              catchtouchcancel="onSwapCardTouchEnd"
            >
              <text
                class="num pos-{{item.pos}} {{item.number === teamACaptainNo ? 'captain-num' : ''}} {{hideTeamAMainNumbers ? 'num-hidden' : ''}} {{item.isLibero ? 'libero-dot' : ''}}"
              >{{item.number}}</text>
              <text class="sub-text">{{item.pos}}</text>
              <text class="serve-mark {{item.pos === 'I' && servingTeam === 'A' ? 'active' : ''}}">发</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="team-panel team-b">
      <view class="team-head">
        <block wx:if="{{!isSwapped}}">
          <text class="team-title align-left">{{teamBName}}</text>
          <view class="team-actions right">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="B" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="B"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="B" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="team-actions left">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="B" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="B"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="B" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
          <text class="team-title align-right">{{teamBName}}</text>
        </block>
      </view>
      <view class="lineup-grid reverse {{isSwapped ? 'swap-layout' : ''}}">
        <view class="main-col">
          <view class="player-row row-two" wx:for="{{teamBMainGrid}}" wx:for-item="row" wx:key="index">
            <view
              id="swap-card-B-{{item.pos}}"
              class="player-card pos-card-{{item.pos}} {{item.pos === 'I' && servingTeam === 'B' ? 'score-pos-one' : ''}} {{swapDragActive && swapDragTeam === 'B' && swapDragPos === item.pos ? 'swap-drag-source' : ''}} {{swapDragActive && swapDragTeam === 'B' && swapDragPos !== item.pos && swapDragSourceIsLibero && ((item.pos === 'I' && swapDragTargetI) || (item.pos === 'II' && swapDragTargetII) || (item.pos === 'III' && swapDragTargetIII) || (item.pos === 'IV' && swapDragTargetIV) || (item.pos === 'V' && swapDragTargetV) || (item.pos === 'VI' && swapDragTargetVI)) ? 'swap-drag-target' : ''}}"
              wx:for="{{row}}"
              wx:for-item="item"
              wx:key="pos"
              data-team="B"
              data-pos="{{item.pos}}"
              catchtouchstart="onSwapCardTouchStart"
              catchtouchmove="onSwapCardTouchMove"
              catchtouchend="onSwapCardTouchEnd"
              catchtouchcancel="onSwapCardTouchEnd"
            >
              <text
                class="num pos-{{item.pos}} {{item.number === teamBCaptainNo ? 'captain-num' : ''}} {{hideTeamBMainNumbers ? 'num-hidden' : ''}} {{item.isLibero ? 'libero-dot' : ''}}"
              >{{item.number}}</text>
              <text class="sub-text">{{item.pos}}</text>
              <text class="serve-mark {{item.pos === 'I' && servingTeam === 'B' ? 'active' : ''}}">发</text>
            </view>
          </view>
        </view>
        <view class="libero-col">
          <view
            id="swap-card-B-{{item.pos}}"
            class="player-card libero {{swapDragActive && swapDragTeam === 'B' && swapDragPos === item.pos ? 'swap-drag-source' : ''}} {{swapDragActive && swapDragTeam === 'B' && swapDragPos !== item.pos && swapDragSourceInMain && ((item.pos === 'L1' && swapDragTargetL1) || (item.pos === 'L2' && swapDragTargetL2)) ? 'swap-drag-target' : ''}}"
            wx:for="{{teamBLibero}}"
            wx:for-item="item"
            wx:key="pos"
            data-team="B"
            data-pos="{{item.pos}}"
            catchtouchstart="onSwapCardTouchStart"
            catchtouchmove="onSwapCardTouchMove"
            catchtouchend="onSwapCardTouchEnd"
            catchtouchcancel="onSwapCardTouchEnd"
          >
            <text class="num {{item.number === teamBCaptainNo ? 'captain-num' : ''}} {{item.isLibero ? 'libero-dot' : ''}}">{{item.number}}</text>
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{swapDragGhostVisible}}"
    class="swap-drag-ghost team-{{swapDragGhostTeam === 'B' ? 'b' : 'a'}} {{swapDragSourceIsLibero ? 'libero' : ''}}"
    style="{{swapDragGhostStyle}}"
  >
    <text class="num {{swapDragGhostIsCaptain ? 'captain-num' : ''}} {{swapDragGhostIsLibero ? 'libero-dot' : ''}}">{{swapDragGhostNumber}}</text>
    <text class="sub-text">{{swapDragGhostPos}}</text>
  </view>

  <view class="rotate-fly-layer" wx:if="{{rotateFlyItemsA.length || rotateFlyItemsB.length}}">
    <view
      wx:for="{{rotateFlyItemsA}}"
      wx:key="id"
      wx:for-item="item"
      class="rotate-fly-item team-a"
      style="{{item.style}}"
    >
      <text class="num {{item.isCaptain ? 'captain-num' : ''}} {{item.isLibero ? 'libero-dot' : ''}}">{{item.number}}</text>
    </view>
    <view
      wx:for="{{rotateFlyItemsB}}"
      wx:key="id"
      wx:for-item="item"
      class="rotate-fly-item team-b"
      style="{{item.style}}"
    >
      <text class="num {{item.isCaptain ? 'captain-num' : ''}} {{item.isLibero ? 'libero-dot' : ''}}">{{item.number}}</text>
    </view>
  </view>

  <view class="set-end-mask" wx:if="{{showSetEndModal}}" bindtap="onSetEndModalTap">
    <view class="set-end-modal" catchtap="onSetEndModalTap">
      <view class="set-end-title-top">{{setEndTitleTop}}</view>
      <view class="set-end-title-bottom" wx:if="{{setEndTitleBottom}}">{{setEndTitleBottom}}</view>

      <view class="set-end-body">
        <view class="set-end-score-panels">
          <view class="set-end-score-panel">
            <text class="set-end-section-label">小比分</text>
            <view class="set-end-compare-line">
              <text class="set-end-compare-left">{{setEndTeamAName}}</text>
              <text class="set-end-compare-colon">:</text>
              <text class="set-end-compare-right">{{setEndTeamBName}}</text>
            </view>
            <view class="set-end-score-line">
              <text class="set-end-score">{{setEndSmallScoreA}}</text>
              <text class="set-end-score-sep">:</text>
              <text class="set-end-score">{{setEndSmallScoreB}}</text>
            </view>
          </view>
          <view class="set-end-score-panel">
            <text class="set-end-section-label">大比分</text>
            <view class="set-end-compare-line">
              <text class="set-end-compare-left">{{setEndTeamAName}}</text>
              <text class="set-end-compare-colon">:</text>
              <text class="set-end-compare-right">{{setEndTeamBName}}</text>
            </view>
            <view class="set-end-score-line">
              <text class="set-end-score">{{setEndBigScoreA}}</text>
              <text class="set-end-score-sep">:</text>
              <text class="set-end-score">{{setEndBigScoreB}}</text>
            </view>
          </view>
        </view>

        <text class="set-end-winner">本局{{setEndWinnerName}}队胜</text>
        <text class="set-end-duration">局时间 {{setEndDurationText}}</text>
        <text class="set-end-winner" wx:if="{{setEndMatchFinished}}">比赛结束 {{setEndWinnerName}}队胜</text>
      </view>

      <view class="set-end-actions" wx:if="{{hasOperationAuthority}}">
        <block wx:if="{{setEndWaiting}}">
          <view class="set-end-btn-home waiting waiting-main">
            <view class="set-end-btn-content waiting-content">
              <text class="set-end-btn-text">等待其他裁判操作中...</text>
            </view>
          </view>
          <view class="set-end-btn-home takeover waiting-takeover pressable" hover-class="tap-active" bindtap="onSetEndTakeover">
            <view class="set-end-btn-content leading-content">
              <view class="set-end-btn-icon takeover"></view>
              <text class="set-end-btn-text">接管</text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="set-end-btn-home outline pressable" hover-class="tap-active" bindtap="onSetEndUndo">
            <view class="set-end-btn-content">
              <text class="set-end-btn-text">撤回最后一分</text>
              <view class="set-end-btn-icon undo"></view>
            </view>
          </view>
          <view class="set-end-btn-home primary pressable" hover-class="tap-active" bindtap="onSetEndContinue">
            <view class="set-end-btn-content">
              <text class="set-end-btn-text">{{setEndActionText}}</text>
              <view class="set-end-btn-icon {{setEndMatchFinished ? 'confirm' : ''}}"></view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="back-exit-mask" wx:if="{{showBackExitModal}}" bindtap="onBackExitCancel">
    <view class="back-exit-modal" catchtap="onBackExitModalTap">
      <view class="back-exit-title">退出确认</view>
      <view class="back-exit-text">
        退出房间将返回首页，再次进入需要提供完整的裁判团队编号和密码，确认退出吗？
      </view>
      <view class="back-exit-subtext">可先复制邀请信息，返回后在加入页面粘贴快速重新加入。</view>
      <view class="back-exit-actions">
        <view class="back-exit-btn pressable" hover-class="tap-active" bindtap="onBackExitCancel">取消</view>
        <view class="back-exit-btn danger pressable" hover-class="tap-active" bindtap="onBackExitDirect">退出</view>
        <view class="back-exit-btn primary pressable" hover-class="tap-active" bindtap="onBackExitCopyAndLeave">复制邀请并退出</view>
      </view>
    </view>
  </view>

  <view class="log-mask" wx:if="{{showLogPanel}}" bindtap="onCloseLogPanel">
    <view class="log-panel" style="{{logPanelInlineStyle}}" catchtap="onLogPanelTap">
      <view class="log-head">
        <text class="log-title sub-panel-title">操作记录</text>
        <view class="log-head-right">
          <view class="log-set-switch" wx:if="{{logSetSwitchVisible}}">
            <text class="log-set-label">局</text>
            <view class="log-set-seg">
              <view
                class="log-set-item {{selectedLogSet === item ? 'active' : ''}}"
                wx:for="{{logSetOptions}}"
                wx:key="*this"
                wx:for-item="item"
                data-set-no="{{item}}"
                bindtap="onSelectLogSet"
              >{{item}}</view>
            </view>
          </view>
          <button class="plain-btn small" size="mini" bindtap="onCloseLogPanel">关闭</button>
        </view>
      </view>
      <scroll-view class="log-list" scroll-y="true">
        <view class="log-item" wx:for="{{logs}}" wx:key="id" wx:for-item="item">
          <text class="log-time">{{item.timeText}}</text>
          <text class="log-note">{{item.note}}</text>
        </view>
        <view class="log-empty" wx:if="{{!logs.length}}">暂无记录</view>
      </scroll-view>
    </view>
  </view>

  <view class="log-mask" wx:if="{{showSubstitutionPanel}}" bindtap="onCloseSubstitutionPanel">
    <view class="log-panel substitution-panel" catchtap="onSubstitutionPanelTap">
      <view class="log-head">
        <view class="sub-panel-title-wrap">
          <text class="log-title sub-panel-title">局中换人</text>
          <text class="sub-panel-tip">自由人常规换人可直接在比赛页拖拽球员卡片到目标球员卡片完成。</text>
        </view>
        <view class="log-head-right">
          <view class="sub-head-record-btn pressable" hover-class="tap-active" bindtap="onToggleSubMatchLogPopover">
            <view class="btn-icon icon-log"></view>
            <text class="sub-head-record-text">记录</text>
          </view>
          <button class="plain-btn small" size="mini" bindtap="onCloseSubstitutionPanel">关闭</button>
        </view>
      </view>

      <view class="sub-main-layout">
        <view class="sub-op-players">
          <text class="sub-editor-left-title">{{subTeamName}}队球员</text>
          <view class="lineup-grid sub-player-grid {{subTeam === 'A' ? 'team-a' : 'team-b'}} {{subUseSwapLayout ? 'swap-layout' : ''}}">
            <view class="libero-col">
              <view
                class="player-card libero {{subSelectedPos === item.pos ? 'sub-player-selected' : ''}}"
                wx:for="{{subLibero}}"
                wx:key="pos"
                wx:for-item="item"
                data-pos="{{item.pos}}"
                bindtap="onSubSelectPlayer"
              >
                <text class="num {{item.number === subCaptainNo ? 'captain-num' : ''}} {{item.isLibero ? 'libero-dot' : ''}}">{{item.number}}</text>
                <text class="sub-text">{{item.pos}}</text>
              </view>
            </view>
            <view class="main-col">
              <view class="player-row row-two" wx:for="{{subMainGrid}}" wx:key="index" wx:for-item="row">
                <view
                  class="player-card {{subSelectedPos === item.pos ? 'sub-player-selected' : ''}}"
                  wx:for="{{row}}"
                  wx:key="pos"
                  wx:for-item="item"
                  data-pos="{{item.pos}}"
                  bindtap="onSubSelectPlayer"
                >
                  <text class="num {{item.number === subCaptainNo ? 'captain-num' : ''}} {{item.isLibero ? 'libero-dot' : ''}}">{{item.number}}</text>
                  <text class="sub-text">{{item.pos}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="sub-op-controls">
          <view class="sub-op-controls-fields">
            <view class="sub-field">
              <text class="sub-field-label">换人类型</text>
              <view class="sub-seg">
                <view class="sub-seg-item {{subMode === 'normal' ? 'active' : ''}}" data-mode="normal" bindtap="onSubSelectMode">普通 ({{subNormalCount}}/6)</view>
                <view class="sub-seg-item {{subMode === 'special' ? 'active' : ''}}" data-mode="special" bindtap="onSubSelectMode">特殊 ({{subSpecialCount}}/∞)</view>
                <view class="sub-seg-item {{subMode === 'special_libero' ? 'active' : ''}}" data-mode="special_libero" bindtap="onSubSelectMode">自由人特殊 ({{subSpecialLiberoRecords.length}}/∞)</view>
              </view>
            </view>

            <view class="sub-field">
              <text class="sub-field-label">换上号码</text>
              <input
                class="sub-no-input"
                type="number"
                maxlength="2"
                value="{{subIncomingNoInput}}"
                bindinput="onSubIncomingNoInput"
                bindblur="onSubIncomingNoBlur"
              />
            </view>

            <view class="sub-field sub-special-reason-field {{(subMode === 'special' || subMode === 'special_libero') ? 'visible' : 'hidden'}}">
              <text class="sub-field-label">换人原因</text>
              <view class="sub-seg">
                <view class="sub-seg-item {{subReason === 'injury' ? 'active' : ''}}" data-reason="injury" bindtap="onSubSelectReason">伤病</view>
                <view class="sub-seg-item {{subReason === 'penalty_set' ? 'active' : ''}}" data-reason="penalty_set" bindtap="onSubSelectReason">处罚 (本局禁赛)</view>
                <view class="sub-seg-item {{subReason === 'penalty_match' ? 'active' : ''}}" data-reason="penalty_match" bindtap="onSubSelectReason">处罚 (全场禁赛)</view>
                <view class="sub-seg-item {{subReason === 'other' ? 'active' : ''}}" data-reason="other" bindtap="onSubSelectReason">其他</view>
              </view>
            </view>

            <view class="sub-confirm-wrap">
              <view class="set-end-btn-home sub-confirm-btn pressable" hover-class="tap-active" bindtap="onSubConfirmTap">
                <view class="set-end-btn-content sub-confirm-btn-content">
                  <text class="sub-confirm-btn-text">确认换人</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="sub-log-popover-mask" wx:if="{{showSubMatchLogPopover}}" bindtap="onCloseSubMatchLogPopover">
        <view class="sub-log-popover" style="{{subLogPopoverInlineStyle}}" catchtap="onSubMatchLogPopoverTap">
          <view class="log-head sub-log-popover-head">
            <text class="log-title">换人记录</text>
          </view>
          <view class="sub-record-tabbar">
            <view class="sub-seg" id="sub-log-tab-seg">
              <view class="sub-seg-item {{subRecordTab === 'normal' ? 'active' : ''}}" data-tab="normal" bindtap="onSelectSubRecordTab">普通</view>
              <view class="sub-seg-item {{subRecordTab === 'special' ? 'active' : ''}}" data-tab="special" bindtap="onSelectSubRecordTab">特殊</view>
              <view class="sub-seg-item {{subRecordTab === 'libero' ? 'active' : ''}}" data-tab="libero" bindtap="onSelectSubRecordTab">自由人常规</view>
              <view class="sub-seg-item {{subRecordTab === 'special_libero' ? 'active' : ''}}" data-tab="special_libero" bindtap="onSelectSubRecordTab">自由人特殊</view>
            </view>
          </view>
          <scroll-view class="log-list sub-log-popover-list" scroll-y="true">
            <view class="log-item" wx:if="{{subRecordTab === 'normal'}}" wx:for="{{subNormalRecords}}" wx:key="index" wx:for-item="item">
              <text class="log-time">{{item.index}}</text>
              <text class="log-note">{{item.text}}</text>
            </view>
            <view class="log-item" wx:if="{{subRecordTab === 'special'}}" wx:for="{{subSpecialRecords}}" wx:key="index" wx:for-item="item">
              <text class="log-time">{{item.index}}</text>
              <text class="log-note">{{item.text}}</text>
            </view>
            <view class="log-item" wx:if="{{subRecordTab === 'libero'}}" wx:for="{{subLiberoRecords}}" wx:key="index" wx:for-item="item">
              <text class="log-time">{{item.index}}</text>
              <text class="log-note">{{item.text}}</text>
            </view>
            <view class="log-item" wx:if="{{subRecordTab === 'special_libero'}}" wx:for="{{subSpecialLiberoRecords}}" wx:key="index" wx:for-item="item">
              <text class="log-time">{{item.index}}</text>
              <text class="log-note">{{item.text}}</text>
            </view>
            <view class="log-empty" wx:if="{{subRecordTab === 'normal' && !subNormalRecords.length}}">暂无普通换人记录</view>
            <view class="log-empty" wx:if="{{subRecordTab === 'special' && !subSpecialRecords.length}}">暂无特殊换人记录</view>
            <view class="log-empty" wx:if="{{subRecordTab === 'libero' && !subLiberoRecords.length}}">暂无自由人常规换人记录</view>
            <view class="log-empty" wx:if="{{subRecordTab === 'special_libero' && !subSpecialLiberoRecords.length}}">暂无自由人特殊换人记录</view>
          </scroll-view>
        </view>
      </view>
    </view>
  </view>

  <view id="sub-panel-size-probe" class="substitution-panel sub-panel-size-probe"></view>
</view>
