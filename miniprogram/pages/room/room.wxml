<view
  class="room-container"
  style="--team-a-color: {{teamAColor}}; --team-b-color: {{teamBColor}};"
>
  <view class="card room-settings">
    <text class="team-label">比赛设置</text>
    <view class="setting-row">
      <text class="label">赛制模式</text>
      <picker
        mode="selector"
        range="{{matchModes}}"
        range-key="label"
        value="{{matchModeIndex}}"
        disabled="{{!createMode}}"
        bindchange="onMatchModeChange"
      >
        <view class="input team-name picker-value">{{matchModes[matchModeIndex].label}}</view>
      </picker>
    </view>
    <view class="setting-row">
      <text class="label">甲队名称</text>
      <input
        class="input team-name input-left"
        value="{{teamAName}}"
        placeholder="{{teamANameFocused ? '' : '甲'}}"
        disabled="{{!createMode}}"
        data-field="teamAName"
        bindfocus="onTeamNameFocus"
        bindblur="onTeamNameBlur"
        bindinput="onInputChange"
      />
    </view>
    <view class="setting-row color-row">
      <text class="label">甲队颜色</text>
      <view class="color-options">
        <view
          class="color-option {{teamAColor === item.value ? 'active' : ''}} {{teamBColor === item.value ? 'disabled' : ''}}"
          wx:for="{{colorOptions}}"
          wx:key="value"
          data-team="A"
          data-color="{{item.value}}"
          hover-class="{{createMode ? 'color-option-hover' : ''}}"
          bindtap="onTeamColorSelect"
        >
          <view class="color-dot" style="background-color: {{item.value}};"></view>
        </view>
      </view>
    </view>
    <view class="setting-row">
      <text class="label">乙队名称</text>
      <input
        class="input team-name input-left"
        value="{{teamBName}}"
        placeholder="{{teamBNameFocused ? '' : '乙'}}"
        disabled="{{!createMode}}"
        data-field="teamBName"
        bindfocus="onTeamNameFocus"
        bindblur="onTeamNameBlur"
        bindinput="onInputChange"
      />
    </view>
    <view class="setting-row color-row">
      <text class="label">乙队颜色</text>
      <view class="color-options">
        <view
          class="color-option {{teamBColor === item.value ? 'active' : ''}} {{teamAColor === item.value ? 'disabled' : ''}}"
          wx:for="{{colorOptions}}"
          wx:key="value"
          data-team="B"
          data-color="{{item.value}}"
          hover-class="{{createMode ? 'color-option-hover' : ''}}"
          bindtap="onTeamColorSelect"
        >
          <view class="color-dot" style="background-color: {{item.value}};"></view>
        </view>
      </view>
    </view>
    <view class="setting-row" wx:if="{{!createMode}}">
      <text class="label">房间密码</text>
      <input
        class="input team-name input-left"
        type="number"
        maxlength="6"
        placeholder="{{passwordFocused ? '' : '6位数字'}}"
        value="{{roomPassword}}"
        data-field="roomPassword"
        bindfocus="onPasswordFocus"
        bindblur="onPasswordBlur"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <view class="card team team-a">
    <view class="team-head-row">
      <text class="team-title">{{teamAName || '甲'}}队 首发队员</text>
      <view class="team-switches">
        <view
          class="toggle-item switch-btn pressable {{servingTeam === 'A' ? 'on' : ''}} {{servePulseTeam === 'A' ? 'switch-pulse' : ''}}"
          data-team="A"
          hover-class="tap-active"
          bindtap="onTeamServeButton"
        >
          <text class="toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
          <view class="serve-toggle-icon"></view>
        </view>
        <view class="side-toggle-btn switch-btn pressable {{sidePulse ? 'switch-pulse' : ''}}" hover-class="tap-active" bindtap="onToggleTeamSide">
          <text>{{teamASide === 'A' ? 'A场区' : 'B场区'}}</text>
          <view class="side-toggle-icon"></view>
        </view>
      </view>
    </view>

    <view class="lineup-grid">
      <view class="main-col">
        <view class="player-row row-two" wx:for="{{teamAMainGrid}}" wx:for-item="row" wx:key="index">
          <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos">
            <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="A" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="libero-col">
        <view class="player-card libero" wx:for="{{teamALibero}}" wx:for-item="item" wx:key="pos">
          <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="A" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
          <text class="sub-text">{{item.pos}}</text>
        </view>
      </view>
    </view>

    <view class="setting-row captain-row">
      <text class="label">队长号码</text>
      <input
        class="input team-name input-left"
        type="number"
        maxlength="2"
        value="{{teamACaptainNo}}"
        data-field="teamACaptainNo"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <view class="card team team-b">
    <view class="team-head-row">
      <text class="team-title">{{teamBName || '乙'}}队 首发队员</text>
      <view class="team-switches">
        <view
          class="toggle-item switch-btn pressable {{servingTeam === 'B' ? 'on' : ''}} {{servePulseTeam === 'B' ? 'switch-pulse' : ''}}"
          data-team="B"
          hover-class="tap-active"
          bindtap="onTeamServeButton"
        >
          <text class="toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
          <view class="serve-toggle-icon"></view>
        </view>
        <view class="side-toggle-btn switch-btn pressable {{sidePulse ? 'switch-pulse' : ''}}" hover-class="tap-active" bindtap="onToggleTeamSide">
          <text>{{teamASide === 'B' ? 'A场区' : 'B场区'}}</text>
          <view class="side-toggle-icon"></view>
        </view>
      </view>
    </view>

    <view class="lineup-grid">
      <view class="main-col">
        <view class="player-row row-two" wx:for="{{teamBMainGrid}}" wx:for-item="row" wx:key="index">
          <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos">
            <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="B" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="libero-col">
        <view class="player-card libero" wx:for="{{teamBLibero}}" wx:for-item="item" wx:key="pos">
          <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="B" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
          <text class="sub-text">{{item.pos}}</text>
        </view>
      </view>
    </view>

    <view class="setting-row captain-row">
      <text class="label">队长号码</text>
      <input
        class="input team-name input-left"
        type="number"
        maxlength="2"
        value="{{teamBCaptainNo}}"
        data-field="teamBCaptainNo"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <view class="create-actions" wx:if="{{createMode}}">
    <button class="save-btn invite-btn half-btn" bindtap="onCopyInviteAndStart">
      <view class="btn-content">
        <view class="invite-icon"></view>
        <text>复制邀请</text>
      </view>
    </button>
    <button class="save-btn half-btn" bindtap="onSaveAndStart">进入比赛</button>
  </view>
  <button class="save-btn" wx:if="{{!createMode}}" bindtap="onSaveAndStart">进入比赛</button>

  <view class="captain-picker-mask" wx:if="{{showCaptainPicker}}" catchtouchmove="noop" bindtap="onCaptainPickerCancel">
    <view class="captain-picker-panel" catchtap="noop">
      <view class="captain-picker-title">{{captainPickerTitle}}</view>
      <view class="captain-picker-tip">请选择当前在场上的队长号码</view>
      <view class="lineup-grid captain-picker-grid {{captainPickerTeam === 'A' ? 'team-a' : 'team-b'}}">
        <view class="main-col">
          <view class="player-row row-two" wx:for="{{captainPickerMainGrid}}" wx:key="index" wx:for-item="row">
            <view
              class="player-card captain-option-card {{captainPickerSelectedNo === item.number ? 'captain-option-selected' : ''}}"
              wx:for="{{row}}"
              wx:key="pos"
              wx:for-item="item"
              data-number="{{item.number}}"
              hover-class="tap-active"
              bindtap="onCaptainPickerSelect"
            >
              <text class="num-text">{{item.number}}</text>
              <text class="sub-text">{{item.pos}}</text>
            </view>
          </view>
        </view>
        <view class="libero-col">
          <view
            class="player-card libero captain-option-card {{captainPickerSelectedNo === item.number ? 'captain-option-selected' : ''}}"
            wx:for="{{captainPickerLibero}}"
            wx:key="pos"
            wx:for-item="item"
            data-number="{{item.number}}"
            hover-class="tap-active"
            bindtap="onCaptainPickerSelect"
          >
            <text class="num-text">{{item.number}}</text>
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="captain-picker-actions">
        <button class="captain-picker-btn cancel" bindtap="onCaptainPickerCancel">取消</button>
        <button class="captain-picker-btn confirm" bindtap="onCaptainPickerConfirm">确定</button>
      </view>
    </view>
  </view>
</view>
