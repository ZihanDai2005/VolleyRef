<view
  class="match-page match-container {{matchFlowMode === 'between_sets' ? 'flow-between' : ''}} {{matchFlowMode === 'edit_players' ? 'flow-edit' : ''}} {{flowSwitchingOut ? 'flow-switch-out' : ''}} {{flowSwitchingIn ? 'flow-switch-in' : ''}} flow-switch-scope-{{flowSwitchScope}}"
  style="--team-a-color: {{teamAColor}}; --team-b-color: {{teamBColor}}; --team-a-rgb: {{teamARGB}}; --team-b-rgb: {{teamBRGB}}; --safe-pad-top: {{safePadTop}}; --safe-pad-right: {{safePadRight}}; --safe-pad-bottom: {{safePadBottom}}; --safe-pad-left: {{safePadLeft}};"
  bindtap="onMatchBlankTap"
>
  <view class="match-nav">
    <view class="match-nav-left">
      <view class="match-nav-back pressable" hover-class="tap-active" bindtap="confirmBackToHome">
        <view class="match-nav-back-icon"></view>
      </view>
      <view
        wx:if="{{!hasOperationAuthority}}"
        class="takeover-btn {{showSetEndModal ? 'set-end-open' : ''}} pressable"
        hover-class="tap-active"
        bindtap="onTakeoverTap"
      >
        <view class="takeover-btn-icon"></view>
        <text class="takeover-btn-text">接管</text>
      </view>
    </view>
    <view class="match-nav-title">
      <view class="conn-inline {{connStatusClass}}">
        <view class="conn-inline-icon"></view>
        <text class="conn-inline-text">{{connStatusText}}</text>
      </view>
      <view class="nav-fixed-gap"></view>
      <text>裁判团队编号 <text class="nav-code-mono">{{roomId}}</text></text>
      <view class="nav-fixed-gap"></view>
      <text>密码 <text class="nav-code-mono">{{showRoomPassword ? roomPassword : '••••••'}}</text></text>
      <view
        class="password-eye-btn pressable {{passwordEyeFx ? 'fx' : ''}}"
        hover-class="tap-active"
        bindtap="onToggleRoomPasswordVisible"
      >
        <view class="password-eye-icon {{showRoomPassword ? 'eye-close' : 'eye-open'}}"></view>
      </view>
    </view>
    <view class="match-nav-space"></view>
  </view>
  <view wx:if="{{matchFlowMode === 'between_sets'}}" class="between-flow-head">
    <text class="between-flow-title">{{betweenHeadTitle}}</text>
    <text class="between-flow-hint">{{betweenHeadHint}}</text>
    <view
      wx:if="{{hasOperationAuthority}}"
      class="x-room-count-pill center-set-pill start-match-entry-pill pressable between-flow-confirm-btn"
      hover-class="tap-active"
      bindtap="onFlowConfirmTap"
    >
      <view class="start-match-entry-icon confirm"></view>
      <text class="start-match-entry-text">确定</text>
    </view>
  </view>

  <view wx:else class="top-control-row">
    <view class="x-zone">
      <view class="x-row">
        <view wx:if="{{hasOperationAuthority}}" class="action-btn icon-circle-btn pressable" hover-class="tap-active" bindtap="onSwitchSides">
          <view class="btn-icon icon-switch"></view>
        </view>
        <view wx:else class="action-btn perspective-btn pressable" hover-class="tap-active" bindtap="onToggleObserverPerspective">
          <view class="btn-icon icon-switch"></view>
          <text class="perspective-btn-text">视角</text>
        </view>
        <view
          wx:if="{{hasOperationAuthority}}"
          class="action-btn icon-circle-btn pressable"
          hover-class="tap-active"
          bindtap="onUndoLastScore"
        >
          <view class="btn-icon icon-undo"></view>
        </view>
        <view
          wx:if="{{hasOperationAuthority}}"
          class="action-btn icon-circle-btn pressable"
          hover-class="tap-active"
          bindtap="onReconfigurePlayersTap"
        >
          <view class="btn-icon icon-reconfigure"></view>
        </view>
        <view class="action-btn icon-circle-btn pressable" hover-class="tap-active" bindtap="onOpenLogPanel">
          <view class="btn-icon icon-log"></view>
        </view>
      </view>
      <view class="x-row">
        <view class="x-room-count-pill online-pill">
          <view class="online-judge-icon"></view>
          <text>{{participantCount}}</text>
        </view>
        <view class="x-room-count-pill mode-pill">{{hasOperationAuthority ? '裁判模式' : '观赛模式'}}</view>
      </view>
    </view>

    <view class="score-zone {{switchingOut ? 'switch-out' : ''}} {{switchingIn ? 'switch-in' : ''}}">
      <view class="score-normal-shell {{matchFlowMode === 'edit_players' ? 'ghost' : ''}}">
        <view class="score-pill-row">
          <view class="center-pill-switch">
            <view class="x-room-count-pill center-set-pill stat-num-pill score-switch-pill {{(canStartMatch && hasOperationAuthority) ? 'pill-hidden' : 'pill-visible'}}">{{setWinsText}}</view>
            <view wx:if="{{hasOperationAuthority}}" class="start-match-entry-row score-switch-pill {{canStartMatch ? 'pill-visible' : 'pill-hidden'}}">
              <view
                wx:if="{{!preStartCaptainConfirmed}}"
                class="x-room-count-pill center-set-pill captain-select-entry-pill pressable"
                hover-class="tap-active"
                bindtap="onOpenCaptainConfirmModal"
              >
                <view class="captain-select-entry-icon"></view>
                <text class="start-match-entry-text">确认场上队长</text>
              </view>
              <view
                wx:else
                class="x-room-count-pill center-set-pill start-match-entry-pill pressable"
                hover-class="tap-active"
                bindtap="onOpenStartMatchModal"
              >
                <view class="start-match-entry-icon"></view>
                <text class="start-match-entry-text">开始比赛</text>
              </view>
            </view>
          </view>
          <view class="timeout-live-pill {{timeoutActive ? 'active' : 'inactive'}} {{hasOperationAuthority ? '' : 'observer'}}">
            <text class="timeout-live-text">{{timeoutLeftText}}</text>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-live-end-btn pressable"
              hover-class="tap-active"
              bindtap="onEndTimeoutTap"
            >
              <text class="timeout-live-end-label">结束</text>
            </view>
          </view>
        </view>
        <score-board
          aScore="{{aScore}}"
          bScore="{{bScore}}"
          lastScoringTeam="{{lastScoringTeam}}"
          allowScore="{{hasOperationAuthority}}"
          bind:scoreChange="onScoreChange"
        />
      </view>

      <view wx:if="{{matchFlowMode === 'edit_players'}}" class="edit-flow-center">
        <text class="edit-flow-title">编辑球员模式</text>
        <text class="edit-flow-hint">仅用于修正录入错误，非局中换人，不计入换人记录</text>
        <view wx:if="{{hasOperationAuthority}}" class="start-match-entry-row edit-flow-action-row">
          <view
            class="x-room-count-pill center-set-pill reconfigure-entry-pill pressable edit-flow-cancel-btn"
            hover-class="tap-active"
            bindtap="onFlowCancelTap"
          >
            <text class="reconfigure-entry-text">取消</text>
          </view>
          <view
            class="x-room-count-pill center-set-pill start-match-entry-pill pressable edit-flow-confirm-btn"
            hover-class="tap-active"
            bindtap="onFlowConfirmTap"
          >
            <view class="start-match-entry-icon confirm"></view>
            <text class="start-match-entry-text">确认修改</text>
          </view>
        </view>
      </view>
    </view>

    <view class="y-zone">
      <view class="y-row">
        <view class="x-room-count-pill">{{matchModeText}}</view>
        <view class="x-room-count-pill">{{setNoText}}</view>
      </view>
      <view class="y-row">
        <view class="x-room-count-pill timer-pill"><text class="timer-pill-text">局时间 {{setTimerText}}</text></view>
      </view>
    </view>
  </view>

  <view class="court-row {{isSwapped ? 'swapped' : ''}} {{switchingOut ? 'switch-out' : ''}} {{switchingIn ? 'switch-in' : ''}}">
    <view class="team-panel team-a">
      <view class="team-head">
        <block wx:if="{{!isSwapped}}">
          <view class="team-actions left">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="A" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <block wx:if="{{matchFlowMode === 'between_sets' && hasOperationAuthority}}">
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="A" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'A' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamASideText}}</text>
              </view>
              <view wx:else class="rotate-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
              </view>
            </block>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="A"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="A" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
          <text class="team-title align-right">{{teamAName}}</text>
        </block>
        <block wx:else>
          <text class="team-title align-left">{{teamAName}}</text>
          <view class="team-actions right">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="A" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <block wx:if="{{matchFlowMode === 'between_sets' && hasOperationAuthority}}">
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="A" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'A' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamASideText}}</text>
              </view>
              <view wx:else class="rotate-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
              </view>
            </block>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="A"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamANormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="A" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamATimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
        </block>
      </view>
      <view class="lineup-grid {{isSwapped ? 'swap-layout' : ''}}">
        <view class="libero-col">
          <view
            id="swap-card-A-{{item.pos}}"
            class="player-card {{item.isLibero ? 'libero' : ''}} {{quickSubFlashKey === ('A-' + item.pos) ? 'quick-sub-flash' : ''}} {{swapDragActive && swapDragTeam === 'A' && swapDragPos === item.pos ? 'swap-drag-source' : ''}} {{swapDragActive && swapDragTeam === 'A' && swapDragPos !== item.pos && swapDragSourceIsLibero && ((item.pos === 'L1' && swapDragTargetL1) || (item.pos === 'L2' && swapDragTargetL2)) ? 'swap-drag-target' : ''}}"
            wx:for="{{teamALibero}}"
            wx:for-item="item"
            wx:key="pos"
            data-team="A"
            data-pos="{{item.pos}}"
            data-focus-key="{{'A-' + item.pos}}"
            bindtouchstart="onSwapCardTouchStart"
            bindtouchmove="onSwapCardTouchMove"
            bindtouchend="onSwapCardTouchEnd"
            bindtouchcancel="onSwapCardTouchEnd"
            catchtap="onAdjustFieldWrapTap"
          >
            <input
              adjust-position="false"
              always-embed="true"
              hold-keyboard="false"
              cursor-spacing="0"
              class="player-input pos-{{item.pos}} {{item.number === teamAInitialCaptainNo ? 'captain-input' : ''}}"
              placeholder-class="player-placeholder"
              type="number"
              maxlength="2"
              value="{{item.number === '?' ? '' : item.number}}"
              focus="{{activeAdjustInputKey === ('A-' + item.pos)}}"
              placeholder="?"
              data-team="A"
              data-pos="{{item.pos}}"
              data-focus-key="{{'A-' + item.pos}}"
              bindfocus="onPlayerInputFocus"
              bindinput="onPlayerNumberInput"
              bindblur="onPlayerNumberBlur"
            />
            <view class="player-edit-content">
              <text class="adjust-fake-caret before {{activeAdjustInputKey === ('A-' + item.pos) && item.number === '?' ? 'active' : ''}}"></text>
              <text class="num {{activeAdjustInputKey !== ('A-' + item.pos) && item.number === teamAInitialCaptainNo ? 'captain-num' : ''}} {{matchFlowMode === 'normal' && activeAdjustInputKey !== ('A-' + item.pos) && item.number === teamACaptainNo ? 'current-captain-num' : ''}}" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
              <view wx:if="{{matchFlowMode === 'normal' && activeAdjustInputKey !== ('A-' + item.pos) && item.number !== '?' && item.number === teamACaptainNo && ((item.pos === 'L1' || item.pos === 'L2') || !(hideTeamAMainNumbers && rotateFlyItemsA.length > 0))}}" class="current-captain-mark"></view>
              <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
              <text class="adjust-fake-caret {{activeAdjustInputKey === ('A-' + item.pos) && item.number !== '?' ? 'active' : ''}}"></text>
            </view>
            <text class="sub-text" wx:if="{{item.isLibero}}">{{item.pos}}</text>
          </view>
        </view>
        <view class="main-col">
          <view class="player-row row-two" wx:for="{{teamAMainGrid}}" wx:for-item="row" wx:key="index">
            <view
              id="swap-card-A-{{item.pos}}"
              class="player-card pos-card-{{item.pos}} {{item.isLibero ? 'libero' : ''}} {{quickSubFlashKey === ('A-' + item.pos) ? 'quick-sub-flash' : ''}} {{item.pos === 'I' && servingTeam === 'A' ? 'score-pos-one' : ''}} {{swapDragActive && swapDragTeam === 'A' && swapDragPos === item.pos ? 'swap-drag-source' : ''}} {{swapDragActive && swapDragTeam === 'A' && swapDragPos !== item.pos && swapDragSourceIsLibero && ((item.pos === 'I' && swapDragTargetI) || (item.pos === 'II' && swapDragTargetII) || (item.pos === 'III' && swapDragTargetIII) || (item.pos === 'IV' && swapDragTargetIV) || (item.pos === 'V' && swapDragTargetV) || (item.pos === 'VI' && swapDragTargetVI)) ? 'swap-drag-target' : ''}}"
              wx:for="{{row}}"
              wx:for-item="item"
              wx:key="pos"
              data-team="A"
              data-pos="{{item.pos}}"
              data-focus-key="{{'A-' + item.pos}}"
              bindtouchstart="onSwapCardTouchStart"
              bindtouchmove="onSwapCardTouchMove"
              bindtouchend="onSwapCardTouchEnd"
              bindtouchcancel="onSwapCardTouchEnd"
              catchtap="onAdjustFieldWrapTap"
            >
              <input
                adjust-position="false"
                always-embed="true"
                hold-keyboard="false"
                cursor-spacing="0"
                class="player-input pos-{{item.pos}} {{item.number === teamAInitialCaptainNo ? 'captain-input' : ''}} {{(hideTeamAMainNumbers && rotateFlyItemsA.length > 0) ? 'player-input-hidden' : ''}}"
                placeholder-class="player-placeholder"
                type="number"
                maxlength="2"
                value="{{item.number === '?' ? '' : item.number}}"
                focus="{{activeAdjustInputKey === ('A-' + item.pos)}}"
                placeholder="?"
                data-team="A"
                data-pos="{{item.pos}}"
                data-focus-key="{{'A-' + item.pos}}"
                bindfocus="onPlayerInputFocus"
                bindinput="onPlayerNumberInput"
                bindblur="onPlayerNumberBlur"
              />
              <view class="player-edit-content {{(hideTeamAMainNumbers && rotateFlyItemsA.length > 0) ? 'player-input-hidden' : ''}}">
                <text class="adjust-fake-caret before {{activeAdjustInputKey === ('A-' + item.pos) && item.number === '?' ? 'active' : ''}}"></text>
                <text
                  class="num pos-{{item.pos}} {{activeAdjustInputKey !== ('A-' + item.pos) && item.number === teamAInitialCaptainNo ? 'captain-num' : ''}} {{matchFlowMode === 'normal' && activeAdjustInputKey !== ('A-' + item.pos) && item.number === teamACaptainNo ? 'current-captain-num' : ''}}"
                  wx:if="{{item.number !== '?'}}"
                >{{item.number}}</text>
                <view wx:if="{{matchFlowMode === 'normal' && activeAdjustInputKey !== ('A-' + item.pos) && item.number !== '?' && item.number === teamACaptainNo && ((item.pos === 'L1' || item.pos === 'L2') || !(hideTeamAMainNumbers && rotateFlyItemsA.length > 0))}}" class="current-captain-mark"></view>
                <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                <text class="adjust-fake-caret {{activeAdjustInputKey === ('A-' + item.pos) && item.number !== '?' ? 'active' : ''}}"></text>
              </view>
              <text class="libero-tag" wx:if="{{item.isLibero && item.liberoTag}}">{{item.liberoTag}}</text>
              <text class="sub-text">{{item.pos}}</text>
              <view class="serve-mark {{item.pos === 'I' && servingTeam === 'A' ? 'active' : ''}}"></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="team-panel team-b">
      <view class="team-head">
        <block wx:if="{{!isSwapped}}">
          <text class="team-title align-left">{{teamBName}}</text>
          <view class="team-actions right">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="B" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <block wx:if="{{matchFlowMode === 'between_sets' && hasOperationAuthority}}">
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="B" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'B' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamBSideText}}</text>
              </view>
              <view wx:else class="rotate-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
              </view>
            </block>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="B"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="B" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="team-actions left">
            <view wx:if="{{hasOperationAuthority}}" class="rotate-btn pressable" hover-class="tap-active" data-team="B" bindtap="onRotateTeam">
              <view class="rotate-icon"></view>
            </view>
            <block wx:if="{{matchFlowMode === 'between_sets' && hasOperationAuthority}}">
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="B" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'B' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamBSideText}}</text>
              </view>
              <view wx:else class="rotate-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
              </view>
            </block>
            <view
              wx:if="{{hasOperationAuthority}}"
              class="timeout-btn timeout-btn-extra pressable"
              hover-class="tap-active"
              data-team="B"
              bindtap="onOpenSubstitutionPanel"
            >
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-btn-extra timeout-static">
              <view class="timeout-icon timeout-icon-human"></view>
              <text class="timeout-count">{{teamBNormalSubCount}}<text class="timeout-count-den">/6</text></text>
            </view>
            <view wx:if="{{hasOperationAuthority}}" class="timeout-btn pressable" hover-class="tap-active" data-team="B" bindtap="onTeamTimeoutTap">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
            <view wx:else class="timeout-btn timeout-static">
              <view class="timeout-icon"></view>
              <text class="timeout-count">{{teamBTimeoutCount}}<text class="timeout-count-den">/2</text></text>
            </view>
          </view>
          <text class="team-title align-right">{{teamBName}}</text>
        </block>
      </view>
      <view class="lineup-grid reverse {{isSwapped ? 'swap-layout' : ''}}">
        <view class="main-col">
          <view class="player-row row-two" wx:for="{{teamBMainGrid}}" wx:for-item="row" wx:key="index">
            <view
