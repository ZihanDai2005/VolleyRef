<view class="score-board">
  <view class="team-score a">
    <view
      wx:if="{{allowScore}}"
      class="side-btn score-btn-enter pressable"
      hover-class="tap-active"
      hover-start-time="0"
      hover-stay-time="70"
      bindtap="onAddScoreA"
    >
      <view class="plus-icon"></view>
    </view>
    <view wx:else class="side-btn side-btn-placeholder"></view>
    <text class="score {{pulseA ? 'score-pulse' : ''}} {{lastScoringTeam === 'A' ? 'score-hot' : ''}}">{{aScore}}</text>
  </view>
  <view class="vs">VS</view>
  <view class="team-score b">
    <text class="score {{pulseB ? 'score-pulse' : ''}} {{lastScoringTeam === 'B' ? 'score-hot' : ''}}">{{bScore}}</text>
    <view
      wx:if="{{allowScore}}"
      class="side-btn score-btn-enter pressable"
      hover-class="tap-active"
      hover-start-time="0"
      hover-stay-time="70"
      bindtap="onAddScoreB"
    >
      <view class="plus-icon"></view>
    </view>
    <view wx:else class="side-btn side-btn-placeholder"></view>
  </view>
</view>
