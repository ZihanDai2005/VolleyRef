<view
  class="adjust-page"
  style="--team-a-color: {{teamAColor}}; --team-b-color: {{teamBColor}}; --team-a-rgb: {{teamARGB}}; --team-b-rgb: {{teamBRGB}}; --safe-pad-top: {{safePadTop}}; --safe-pad-right: {{safePadRight}}; --safe-pad-bottom: {{safePadBottom}}; --safe-pad-left: {{safePadLeft}};"
  bindtap="onAdjustBlankTap"
>
  <view class="match-nav">
    <view class="match-nav-left">
      <view wx:if="{{!hasOperationAuthority}}" class="takeover-btn pressable" hover-class="tap-active" bindtap="onTakeoverTap">
        <view class="takeover-btn-icon"></view>
        <text class="takeover-btn-text">接管</text>
      </view>
    </view>
    <view class="match-nav-title">裁判团队编号 {{roomId}}   <text class="conn-inline {{connStatusClass}}">● {{connStatusText}}</text></view>
    <view class="match-nav-space"></view>
  </view>

  <view class="adjust-head-block">
    <text class="adjust-head-title">{{adjustHeadTitle}}</text>
    <text class="adjust-head-hint">{{adjustHeadHint}}</text>
  </view>

  <view class="court-row {{isSwapped ? 'swapped' : ''}} {{switchingOut ? 'switch-out' : ''}} {{switchingIn ? 'switch-in' : ''}}">
    <view class="team-court-wrap">
      <view class="team-panel team-a">
        <view class="team-head">
          <block wx:if="{{!isSwapped}}">
            <view class="team-actions left">
              <view class="rotate-btn pressable" hover-class="tap-active" data-team="A" bindtap="onRotateTeam">
                <view class="rotate-icon"></view>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="A" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'A' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
              </view>
              <view class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamASideText}}</text>
              </view>
            </view>
            <text class="team-title align-right">{{teamAName}}</text>
          </block>
          <block wx:else>
            <text class="team-title align-left">{{teamAName}}</text>
            <view class="team-actions right">
              <view class="rotate-btn pressable" hover-class="tap-active" data-team="A" bindtap="onRotateTeam">
                <view class="rotate-icon"></view>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="A" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'A' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
              </view>
              <view class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamASideText}}</text>
              </view>
            </view>
          </block>
        </view>
        <view class="lineup-grid {{isSwapped ? 'swap-layout' : ''}}">
          <view class="libero-col">
            <view class="player-card libero" wx:for="{{teamALibero}}" wx:for-item="item" wx:key="pos" catchtap="onAdjustFieldWrapTap" data-focus-key="{{item.inputKey}}">
                <input
                  adjust-position="false"
                  always-embed="true"
                  hold-keyboard="true"
                  cursor-spacing="0"
                  class="player-input pos-{{item.pos}} {{item.number === teamACaptainNo ? 'captain-input' : ''}}"
                  placeholder-class="player-placeholder"
                  type="number"
                  maxlength="2"
                  value="{{item.number === '?' ? '' : item.number}}"
                  focus="{{activeAdjustInputKey === item.inputKey}}"
                  placeholder="?"
                  data-team="A"
                  data-index="{{item.index}}"
                  data-focus-key="{{item.inputKey}}"
                bindfocus="onPlayerInputFocus"
                bindinput="onPlayerNumberInput"
                bindblur="onPlayerNumberBlur"
              />
              <view class="player-edit-content">
                <text class="adjust-fake-caret before {{activeAdjustInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                <text class="num {{activeAdjustInputKey !== item.inputKey && item.number === teamACaptainNo ? 'captain-num' : ''}}" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                <text class="adjust-fake-caret {{activeAdjustInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
              </view>
              <text class="sub-text">{{item.pos}}</text>
            </view>
          </view>
          <view class="main-col">
            <view class="player-row row-two" wx:for="{{teamAMainGrid}}" wx:for-item="row" wx:key="index">
              <view class="player-card pos-card-{{item.pos}} {{item.pos === 'I' && servingTeam === 'A' ? 'score-pos-one' : ''}}" wx:for="{{row}}" wx:for-item="item" wx:key="pos" catchtap="onAdjustFieldWrapTap" data-focus-key="{{item.inputKey}}">
                <input
                  adjust-position="false"
                  always-embed="true"
                  hold-keyboard="true"
                  cursor-spacing="0"
                  class="player-input pos-{{item.pos}} {{item.number === teamACaptainNo ? 'captain-input' : ''}} {{hideTeamAMainNumbers ? 'player-input-hidden' : ''}}"
                  placeholder-class="player-placeholder"
                  type="number"
                  maxlength="2"
                  value="{{item.number === '?' ? '' : item.number}}"
                  focus="{{activeAdjustInputKey === item.inputKey}}"
                  placeholder="?"
                  data-team="A"
                  data-index="{{item.index}}"
                  data-focus-key="{{item.inputKey}}"
                  bindfocus="onPlayerInputFocus"
                  bindinput="onPlayerNumberInput"
                  bindblur="onPlayerNumberBlur"
                />
                <view class="player-edit-content {{hideTeamAMainNumbers ? 'player-input-hidden' : ''}}">
                  <text class="adjust-fake-caret before {{activeAdjustInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                  <text class="num {{activeAdjustInputKey !== item.inputKey && item.number === teamACaptainNo ? 'captain-num' : ''}}" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                  <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                  <text class="adjust-fake-caret {{activeAdjustInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
                </view>
                <text class="sub-text">{{item.pos}}</text>
                <text class="serve-mark {{item.pos === 'I' && servingTeam === 'A' ? 'active' : ''}}">发</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="panel-captain-actions">
        <view
          class="panel-captain-btn {{teamACaptainPickDisabled ? 'disabled' : 'pressable'}}"
          hover-class="{{teamACaptainPickDisabled ? '' : 'tap-active'}}"
          data-team="A"
          bindtap="onCaptainPickTap"
        >
          <view class="panel-captain-btn-main">
            <view wx:if="{{teamAShowCaptainCheck}}" class="panel-captain-check-icon"></view>
            <text class="panel-captain-btn-text">{{teamACaptainBtnText}}</text>
          </view>
        </view>
        <view
          wx:if="{{teamAShowCaptainRepick}}"
          class="panel-captain-btn panel-captain-btn-secondary pressable"
          hover-class="tap-active"
          data-team="A"
          bindtap="onCaptainRepickTap"
        >
          <text class="panel-captain-btn-text">重新选择场上队长</text>
        </view>
      </view>
    </view>

    <view class="team-court-wrap">
      <view class="team-panel team-b">
        <view class="team-head">
          <block wx:if="{{!isSwapped}}">
            <text class="team-title align-left">{{teamBName}}</text>
            <view class="team-actions right">
              <view class="rotate-btn pressable" hover-class="tap-active" data-team="B" bindtap="onRotateTeam">
                <view class="rotate-icon"></view>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="B" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'B' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
              </view>
              <view class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamBSideText}}</text>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="team-actions left">
              <view class="rotate-btn pressable" hover-class="tap-active" data-team="B" bindtap="onRotateTeam">
                <view class="rotate-icon"></view>
              </view>
              <view wx:if="{{isDecidingSet}}" class="team-toggle-btn pressable" hover-class="tap-active" data-team="B" bindtap="onToggleServeTeam">
                <view class="serve-toggle-icon {{servingTeam === 'B' ? 'serve' : 'receive'}}"></view>
                <text class="team-toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
              </view>
              <view class="team-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleCourtSide">
                <view class="side-toggle-icon"></view>
                <text class="team-toggle-text">{{teamBSideText}}</text>
              </view>
            </view>
            <text class="team-title align-right">{{teamBName}}</text>
          </block>
        </view>
        <view class="lineup-grid reverse {{isSwapped ? 'swap-layout' : ''}}">
          <view class="main-col">
            <view class="player-row row-two" wx:for="{{teamBMainGrid}}" wx:for-item="row" wx:key="index">
              <view class="player-card pos-card-{{item.pos}} {{item.pos === 'I' && servingTeam === 'B' ? 'score-pos-one' : ''}}" wx:for="{{row}}" wx:for-item="item" wx:key="pos" catchtap="onAdjustFieldWrapTap" data-focus-key="{{item.inputKey}}">
                <input
                  adjust-position="false"
                  always-embed="true"
                  hold-keyboard="true"
                  cursor-spacing="0"
                  class="player-input pos-{{item.pos}} {{item.number === teamBCaptainNo ? 'captain-input' : ''}} {{hideTeamBMainNumbers ? 'player-input-hidden' : ''}}"
                  placeholder-class="player-placeholder"
                  type="number"
                  maxlength="2"
                  value="{{item.number === '?' ? '' : item.number}}"
                  focus="{{activeAdjustInputKey === item.inputKey}}"
                  placeholder="?"
                  data-team="B"
                  data-index="{{item.index}}"
                  data-focus-key="{{item.inputKey}}"
                  bindfocus="onPlayerInputFocus"
                  bindinput="onPlayerNumberInput"
                  bindblur="onPlayerNumberBlur"
                />
                <view class="player-edit-content {{hideTeamBMainNumbers ? 'player-input-hidden' : ''}}">
                  <text class="adjust-fake-caret before {{activeAdjustInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                  <text class="num {{activeAdjustInputKey !== item.inputKey && item.number === teamBCaptainNo ? 'captain-num' : ''}}" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                  <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                  <text class="adjust-fake-caret {{activeAdjustInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
                </view>
                <text class="sub-text">{{item.pos}}</text>
                <text class="serve-mark {{item.pos === 'I' && servingTeam === 'B' ? 'active' : ''}}">发</text>
              </view>
            </view>
          </view>
          <view class="libero-col">
            <view class="player-card libero" wx:for="{{teamBLibero}}" wx:for-item="item" wx:key="pos" catchtap="onAdjustFieldWrapTap" data-focus-key="{{item.inputKey}}">
              <input
                adjust-position="false"
                always-embed="true"
                hold-keyboard="true"
                cursor-spacing="0"
                class="player-input pos-{{item.pos}} {{item.number === teamBCaptainNo ? 'captain-input' : ''}}"
                placeholder-class="player-placeholder"
                type="number"
                maxlength="2"
                value="{{item.number === '?' ? '' : item.number}}"
                focus="{{activeAdjustInputKey === item.inputKey}}"
                placeholder="?"
                data-team="B"
                data-index="{{item.index}}"
                data-focus-key="{{item.inputKey}}"
                bindfocus="onPlayerInputFocus"
                bindinput="onPlayerNumberInput"
                bindblur="onPlayerNumberBlur"
              />
              <view class="player-edit-content">
                <text class="adjust-fake-caret before {{activeAdjustInputKey === item.inputKey && item.number === '?' ? 'active' : ''}}"></text>
                <text class="num {{activeAdjustInputKey !== item.inputKey && item.number === teamBCaptainNo ? 'captain-num' : ''}}" wx:if="{{item.number !== '?'}}">{{item.number}}</text>
                <text class="player-qmark" wx:if="{{item.number === '?'}}">?</text>
                <text class="adjust-fake-caret {{activeAdjustInputKey === item.inputKey && item.number !== '?' ? 'active' : ''}}"></text>
              </view>
              <text class="sub-text">{{item.pos}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="panel-captain-actions">
        <view
          class="panel-captain-btn {{teamBCaptainPickDisabled ? 'disabled' : 'pressable'}}"
          hover-class="{{teamBCaptainPickDisabled ? '' : 'tap-active'}}"
          data-team="B"
          bindtap="onCaptainPickTap"
        >
          <view class="panel-captain-btn-main">
            <view wx:if="{{teamBShowCaptainCheck}}" class="panel-captain-check-icon"></view>
            <text class="panel-captain-btn-text">{{teamBCaptainBtnText}}</text>
          </view>
        </view>
        <view
          wx:if="{{teamBShowCaptainRepick}}"
          class="panel-captain-btn panel-captain-btn-secondary pressable"
          hover-class="tap-active"
          data-team="B"
          bindtap="onCaptainRepickTap"
        >
          <text class="panel-captain-btn-text">重新选择场上队长</text>
        </view>
      </view>
    </view>
  </view>

  <view class="rotate-fly-layer" wx:if="{{rotateFlyItemsA.length || rotateFlyItemsB.length}}">
    <view
      wx:for="{{rotateFlyItemsA}}"
      wx:key="id"
      wx:for-item="item"
      class="rotate-fly-item team-a"
      style="{{item.style}}"
    >
      <text class="num {{item.isCaptain ? 'captain-num' : ''}}">{{item.number}}</text>
    </view>
    <view
      wx:for="{{rotateFlyItemsB}}"
      wx:key="id"
      wx:for-item="item"
      class="rotate-fly-item team-b"
      style="{{item.style}}"
    >
      <text class="num {{item.isCaptain ? 'captain-num' : ''}}">{{item.number}}</text>
    </view>
  </view>

  <view class="adjust-footer">
    <button class="entry-btn {{continueBtnFx ? 'entry-btn-fx' : ''}}" hover-class="entry-btn-hover" bindtap="onContinueTap">
      <view class="entry-btn-content">
        <text class="entry-btn-text">继续</text>
        <view class="entry-btn-icon"></view>
      </view>
    </button>
  </view>

  <view class="captain-picker-mask" wx:if="{{showCaptainPicker}}" catchtouchmove="noop" bindtap="onCaptainPickerCancel">
    <view class="captain-picker-panel" catchtap="noop">
      <view class="captain-picker-title">{{captainPickerTitle}}</view>
      <view class="captain-picker-tip">队长不在场上，请选择一位球员作为场上队长</view>
      <view class="lineup-grid captain-picker-grid {{captainPickerTeam === 'A' ? 'team-a' : 'team-b'}}">
        <view class="main-col">
          <view class="player-row row-two" wx:for="{{captainPickerMainGrid}}" wx:key="index" wx:for-item="row">
            <view
              class="player-card captain-option-card {{captainPickerSelectedNo === item.number ? 'captain-option-selected' : ''}} {{item.number === '?' ? 'captain-option-disabled' : ''}}"
              wx:for="{{row}}"
              wx:key="pos"
              wx:for-item="item"
              data-number="{{item.number}}"
              hover-class="tap-active"
              bindtap="onCaptainPickerSelect"
            >
              <text class="num-text">{{item.number}}</text>
              <text class="sub-text">{{item.pos}}</text>
            </view>
          </view>
        </view>
        <view class="libero-col">
          <view
            class="player-card libero captain-option-card {{captainPickerSelectedNo === item.number ? 'captain-option-selected' : ''}} {{item.number === '?' ? 'captain-option-disabled' : ''}}"
            wx:for="{{captainPickerLibero}}"
            wx:key="pos"
            wx:for-item="item"
            data-number="{{item.number}}"
            hover-class="tap-active"
            bindtap="onCaptainPickerSelect"
          >
            <text class="num-text">{{item.number}}</text>
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="captain-picker-actions">
        <button class="captain-picker-btn cancel" bindtap="onCaptainPickerCancel">取消</button>
        <button class="captain-picker-btn confirm" bindtap="onCaptainPickerConfirm">确定</button>
      </view>
    </view>
  </view>
</view>
