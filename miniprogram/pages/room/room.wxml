<view
  class="room-container"
  style="--team-a-color: {{teamAColor}}; --team-b-color: {{teamBColor}};"
>
  <view class="room-id">
    {{createMode ? '裁判团队编号：' : '房间号：'}}{{roomId}} ｜ {{createMode ? ('密码：' + (roomPassword || '未设置')) : ('人数：' + participantCount)}}
  </view>

  <view class="card room-settings">
    <text class="team-label">比赛设置</text>
    <view class="setting-row">
      <text class="label">赛制模式</text>
      <picker
        mode="selector"
        range="{{matchModes}}"
        range-key="label"
        value="{{matchModeIndex}}"
        bindchange="onMatchModeChange"
      >
        <view class="input team-name picker-value">{{matchModes[matchModeIndex].label}}</view>
      </picker>
    </view>
    <view class="setting-row">
      <text class="label">甲队名称</text>
      <input
        class="input team-name input-left"
        value="{{teamAName}}"
        placeholder="{{teamANameFocused ? '' : '甲'}}"
        data-field="teamAName"
        bindfocus="onTeamNameFocus"
        bindblur="onTeamNameBlur"
        bindinput="onInputChange"
      />
    </view>
    <view class="setting-row color-row">
      <text class="label">甲队颜色</text>
      <view class="color-options">
        <view
          class="color-option {{teamAColor === item.value ? 'active' : ''}} {{teamBColor === item.value ? 'disabled' : ''}}"
          wx:for="{{colorOptions}}"
          wx:key="value"
          data-team="A"
          data-color="{{item.value}}"
          hover-class="color-option-hover"
          bindtap="onTeamColorSelect"
        >
          <view class="color-dot" style="background-color: {{item.value}};"></view>
          <text class="color-name">{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="setting-row">
      <text class="label">乙队名称</text>
      <input
        class="input team-name input-left"
        value="{{teamBName}}"
        placeholder="{{teamBNameFocused ? '' : '乙'}}"
        data-field="teamBName"
        bindfocus="onTeamNameFocus"
        bindblur="onTeamNameBlur"
        bindinput="onInputChange"
      />
    </view>
    <view class="setting-row color-row">
      <text class="label">乙队颜色</text>
      <view class="color-options">
        <view
          class="color-option {{teamBColor === item.value ? 'active' : ''}} {{teamAColor === item.value ? 'disabled' : ''}}"
          wx:for="{{colorOptions}}"
          wx:key="value"
          data-team="B"
          data-color="{{item.value}}"
          hover-class="color-option-hover"
          bindtap="onTeamColorSelect"
        >
          <view class="color-dot" style="background-color: {{item.value}};"></view>
          <text class="color-name">{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="setting-row" wx:if="{{!createMode}}">
      <text class="label">房间密码</text>
      <input
        class="input team-name input-left"
        type="number"
        maxlength="6"
        placeholder="{{passwordFocused ? '' : '6位数字'}}"
        value="{{roomPassword}}"
        data-field="roomPassword"
        bindfocus="onPasswordFocus"
        bindblur="onPasswordBlur"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <view class="card team" id="team-a">
    <view class="team-head-row">
      <text class="team-title">{{teamAName || '甲'}}队 首发队员</text>
      <view class="team-switches">
        <view
          class="toggle-item pressable {{servingTeam === 'A' ? 'on' : ''}}"
          data-team="A"
          hover-class="tap-active"
          bindtap="onTeamServeButton"
        >
          <view class="toggle-track"><view class="toggle-thumb"></view></view>
          <text class="toggle-text">{{servingTeam === 'A' ? '发球' : '接发'}}</text>
        </view>
        <view class="side-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleTeamSide">
          <text>{{teamASide === 'A' ? 'A边' : 'B边'}}</text>
          <view class="side-toggle-icon"></view>
        </view>
      </view>
    </view>

    <view class="lineup-grid">
      <view class="main-col">
        <view class="player-row row-two" wx:for="{{teamAMainGrid}}" wx:for-item="row" wx:key="index">
          <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos">
            <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="A" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="libero-col">
        <view class="player-card libero" wx:for="{{teamALibero}}" wx:for-item="item" wx:key="pos">
          <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="A" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
          <text class="sub-text">{{item.pos}}</text>
        </view>
      </view>
    </view>

    <view class="setting-row captain-row">
      <text class="label">队长号码</text>
      <input
        class="input team-name input-left"
        type="number"
        maxlength="2"
        value="{{teamACaptainNo}}"
        data-field="teamACaptainNo"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <view class="card team" id="team-b">
    <view class="team-head-row">
      <text class="team-title">{{teamBName || '乙'}}队 首发队员</text>
      <view class="team-switches">
        <view
          class="toggle-item pressable {{servingTeam === 'B' ? 'on' : ''}}"
          data-team="B"
          hover-class="tap-active"
          bindtap="onTeamServeButton"
        >
          <view class="toggle-track"><view class="toggle-thumb"></view></view>
          <text class="toggle-text">{{servingTeam === 'B' ? '发球' : '接发'}}</text>
        </view>
        <view class="side-toggle-btn pressable" hover-class="tap-active" bindtap="onToggleTeamSide">
          <text>{{teamASide === 'B' ? 'A边' : 'B边'}}</text>
          <view class="side-toggle-icon"></view>
        </view>
      </view>
    </view>

    <view class="lineup-grid">
      <view class="main-col">
        <view class="player-row row-two" wx:for="{{teamBMainGrid}}" wx:for-item="row" wx:key="index">
          <view class="player-card" wx:for="{{row}}" wx:for-item="item" wx:key="pos">
            <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="B" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
            <text class="sub-text">{{item.pos}}</text>
          </view>
        </view>
      </view>
      <view class="libero-col">
        <view class="player-card libero" wx:for="{{teamBLibero}}" wx:for-item="item" wx:key="pos">
          <input class="player-input" placeholder-class="player-placeholder" type="number" maxlength="2" value="{{item.number === '?' ? '' : item.number}}" placeholder="?" data-team="B" data-index="{{item.index}}" bindinput="onPlayerNumberInput" bindblur="onPlayerNumberBlur" />
          <text class="sub-text">{{item.pos}}</text>
        </view>
      </view>
    </view>

    <view class="setting-row captain-row">
      <text class="label">队长号码</text>
      <input
        class="input team-name input-left"
        type="number"
        maxlength="2"
        value="{{teamBCaptainNo}}"
        data-field="teamBCaptainNo"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <button class="save-btn" bindtap="onSaveAndStart">进入比赛</button>
</view>
