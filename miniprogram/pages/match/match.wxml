        </view>
      </view>
      <view class="captain-confirm-body">
        <view class="captain-confirm-layout {{isSwapped ? 'swapped' : ''}}">
          <view class="captain-confirm-team team-a-panel {{captainConfirmReadonlyA ? 'captain-confirm-team-readonly' : ''}}">
            <view class="captain-confirm-team-head captain-confirm-team-head-a">
              <text class="team-title observer-center captain-confirm-team-name">{{teamAName}}</text>
            </view>
            <view class="lineup-grid sub-player-grid team-a {{isSwapped ? 'swap-layout' : ''}}">
              <view class="libero-col">
                <view
                  class="player-card {{item.isLibero ? 'libero' : ''}} {{captainConfirmSelectedA === item.number ? 'sub-player-selected' : ''}} captain-libero-disabled"
                  wx:for="{{captainConfirmTeamALibero}}"
                  wx:key="pos"
                  wx:for-item="item"
                >
                  <text class="num {{item.number === teamAInitialCaptainNo ? 'captain-num' : ''}} {{item.number === captainConfirmSelectedA ? 'current-captain-num' : ''}}">{{item.number}}</text>
                  <view wx:if="{{item.number === captainConfirmSelectedA}}" class="current-captain-mark"></view>
                  <text class="sub-text" wx:if="{{item.isLibero}}">{{item.pos}}</text>
                </view>
              </view>
              <view class="main-col">
                <view class="player-row row-two" wx:for="{{captainConfirmTeamAMainGrid}}" wx:key="index" wx:for-item="row">
                  <view
                    class="player-card {{item.isLibero ? 'libero' : ''}} {{captainConfirmSelectedA === item.number ? 'sub-player-selected' : ''}} {{captainConfirmReadonlyA ? 'captain-confirm-readonly-card' : ''}} {{item.number === '?' || (!captainConfirmReadonlyA && captainConfirmLockA && captainConfirmSelectedA !== item.number) ? 'sub-player-disabled' : ''}}"
                    wx:for="{{row}}"
                    wx:key="pos"
                    wx:for-item="item"
                    data-team="A"
                    data-number="{{item.number}}"
                    data-pos="{{item.pos}}"
                    bindtap="onCaptainConfirmSelect"
                  >
                    <text class="num {{item.number === teamAInitialCaptainNo ? 'captain-num' : ''}} {{item.number === captainConfirmSelectedA ? 'current-captain-num' : ''}}">{{item.number}}</text>
                    <view wx:if="{{item.number === captainConfirmSelectedA}}" class="current-captain-mark"></view>
                    <text class="libero-tag" wx:if="{{item.isLibero && item.liberoTag}}">{{item.liberoTag}}</text>
                    <text class="sub-text">{{item.pos}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
          <view class="captain-confirm-team team-b-panel {{captainConfirmReadonlyB ? 'captain-confirm-team-readonly' : ''}}">
            <view class="captain-confirm-team-head captain-confirm-team-head-b">
              <text class="team-title observer-center captain-confirm-team-name">{{teamBName}}</text>
            </view>
            <view class="lineup-grid reverse sub-player-grid team-b {{isSwapped ? 'swap-layout' : ''}}">
              <view class="main-col">
                <view class="player-row row-two" wx:for="{{captainConfirmTeamBMainGrid}}" wx:key="index" wx:for-item="row">
                  <view
                    class="player-card {{item.isLibero ? 'libero' : ''}} {{captainConfirmSelectedB === item.number ? 'sub-player-selected' : ''}} {{captainConfirmReadonlyB ? 'captain-confirm-readonly-card' : ''}} {{item.number === '?' || (!captainConfirmReadonlyB && captainConfirmLockB && captainConfirmSelectedB !== item.number) ? 'sub-player-disabled' : ''}}"
                    wx:for="{{row}}"
                    wx:key="pos"
                    wx:for-item="item"
                    data-team="B"
                    data-number="{{item.number}}"
                    data-pos="{{item.pos}}"
                    bindtap="onCaptainConfirmSelect"
                  >
                    <text class="num {{item.number === teamBInitialCaptainNo ? 'captain-num' : ''}} {{item.number === captainConfirmSelectedB ? 'current-captain-num' : ''}}">{{item.number}}</text>
                    <view wx:if="{{item.number === captainConfirmSelectedB}}" class="current-captain-mark"></view>
                    <text class="libero-tag" wx:if="{{item.isLibero && item.liberoTag}}">{{item.liberoTag}}</text>
                    <text class="sub-text">{{item.pos}}</text>
                  </view>
                </view>
              </view>
              <view class="libero-col">
                <view
                  class="player-card {{item.isLibero ? 'libero' : ''}} {{captainConfirmSelectedB === item.number ? 'sub-player-selected' : ''}} captain-libero-disabled"
                  wx:for="{{captainConfirmTeamBLibero}}"
                  wx:key="pos"
                  wx:for-item="item"
                >
                  <text class="num {{item.number === teamBInitialCaptainNo ? 'captain-num' : ''}} {{item.number === captainConfirmSelectedB ? 'current-captain-num' : ''}}">{{item.number}}</text>
                  <view wx:if="{{item.number === captainConfirmSelectedB}}" class="current-captain-mark"></view>
                  <text class="sub-text" wx:if="{{item.isLibero}}">{{item.pos}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="captain-confirm-footer">
        <view class="captain-confirm-actions {{captainConfirmShowCancel ? 'with-cancel' : ''}}">
          <view
            wx:if="{{captainConfirmShowCancel}}"
            class="set-end-btn-home outline captain-confirm-cancel-btn pressable"
            hover-class="tap-active"
            bindtap="onCaptainConfirmCancel"
          >
            <view class="set-end-btn-content captain-confirm-cancel-content">
              <text class="set-end-btn-text">取消</text>
            </view>
          </view>
          <view class="captain-confirm-entry-btn pressable" hover-class="captain-confirm-entry-hover" bindtap="onCaptainConfirmContinue">
            <view class="captain-confirm-entry-content">
              <text class="captain-confirm-entry-text">继续</text>
              <view class="captain-confirm-entry-icon"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view id="sub-panel-size-probe" class="substitution-panel sub-panel-size-probe"></view>
</view>
